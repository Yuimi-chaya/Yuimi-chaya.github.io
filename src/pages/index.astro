---
import BaseLayout from "@/layouts/BaseLayout.astro";

const fallingTags = [
  "Unity3D",
  "Blender",
  "UE5",
  "MMD",
  "AstrBot",
  "猫娘",
  "粉毛",
  "病娇",
  "重女",
  "契约之吻",
  "青春猪头少年",
  "无职转生",
  "夏洛特",
  "Summer Pockets",
  "埃罗芒阿老师",
  "游戏人生",
  "超电磁炮",
  "Cyberpunk 2077",
  "THE FINALS",
  "KovaaK's",
  "Aimlabs",
  "Yuimi Radio",
  "Live2D",
  "小游戏"
];
---

<BaseLayout>
  <section class="hero-stage" data-hero-stage>
    <div class="hero">
      <div class="hero-overlay"></div>
      <button class="home-notice-trigger" type="button" data-notice-open aria-haspopup="dialog">
        <span aria-hidden="true">💌</span>
        今日公告
      </button>
      <div class="hero-copy" data-hero-copy>
        <p class="eyebrow">Personal scrapbook / Anime diary</p>
        <h1 data-title="Yuimi Lab">Yuimi Lab</h1>
        <p class="hero-text terminal-line" aria-label="typing subtitle">
          <span class="hero-terminal-badge" aria-hidden="true"></span>
          <span class="hero-terminal-stack">
            <span class="hero-terminal-status" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
            <span class="hero-terminal-command">
              <span class="terminal-prefix">asteria@lab:~$</span>
              <span class="terminal-typing" data-terminal-typing></span>
            </span>
          </span>
          <span class="terminal-cursor" aria-hidden="true"></span>
        </p>
      </div>

      <div class="hero-profile identity-card" data-hero-profile aria-label="Profile">
        <div class="identity-avatar" data-poke-avatar>
          <span class="avatar-flower" aria-hidden="true">
            <span class="avatar-flower__bloom"></span>
          </span>
          <img src="/assets/profile.jpg" alt="Yuimi Lab avatar" width="168" height="168" />
          <span class="avatar-poke-bubble" data-poke-bubble>&#x64CD;&#x4F5C;&#x592A;&#x5FEB;&#x5566;&#xFF0C;&#x4F11;&#x606F;&#x4E00;&#x4E0B;&#x5427;</span>
        </div>
        <div class="identity-terminal" aria-label="identity terminal card">
          <div class="identity-terminal-bar">
            <div class="terminal-dots" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <span class="terminal-title">yuimi-profile.exe</span>
          </div>
          <p class="identity-path">C:\Users\Yuimi\profile</p>
          <p class="identity-command">
            <span class="terminal-prefix">profile@yuimi:~$</span>
            <span data-name-typing></span>
            <span class="terminal-cursor" aria-hidden="true"></span>
          </p>
          <p class="identity-caption">喝益胃 / Yuimi-chaya</p>
          <div class="social-links" aria-label="Social links">
            <a href="https://github.com/Yuimi-chaya" target="_blank" rel="noreferrer" aria-label="GitHub profile">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.29 9.4 7.86 10.93.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.38-3.87-1.38-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 5.98c.98 0 1.96.13 2.88.39 2.19-1.49 3.15-1.18 3.15-1.18.63 1.59.24 2.77.12 3.06.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.7.41.36.77 1.06.77 2.14v3.18c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
              </svg>
              GitHub
            </a>
            <a href="https://space.bilibili.com/494350222" target="_blank" rel="noreferrer" aria-label="Bilibili profile">
              <svg viewBox="0 0 32 32" aria-hidden="true">
                <path d="M11.1 6.4 8.5 3.8a1.4 1.4 0 0 0-2 2l2.7 2.7h-.7A5.5 5.5 0 0 0 3 14v7.2A5.5 5.5 0 0 0 8.5 26h15A5.5 5.5 0 0 0 29 21.2V14a5.5 5.5 0 0 0-5.5-5.5h-.7l2.7-2.7a1.4 1.4 0 0 0-2-2l-2.6 2.6H11.1Zm-2.6 5h15A2.6 2.6 0 0 1 26.1 14v7.2a2.6 2.6 0 0 1-2.6 2.6h-15a2.6 2.6 0 0 1-2.6-2.6V14a2.6 2.6 0 0 1 2.6-2.6Zm2.7 5.1a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2Zm9.6 0a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2Z" />
              </svg>
              Bilibili
            </a>
          </div>
        </div>
      </div>

      <a class="scroll-cue" href="#main-content" aria-label="Scroll to content">
        <span class="scroll-cue__prompt">scroll@home:~$</span>
        <span class="scroll-cue__arrows" aria-hidden="true">
          <span>&gt;</span>
          <span>&gt;</span>
          <span>&gt;</span>
        </span>
      </a>
    </div>
  </section>

  <div class="home-notice-backdrop" data-notice-backdrop hidden>
    <section class="home-notice-modal" role="dialog" aria-modal="true" aria-labelledby="home-notice-title" data-notice-modal>
      <button class="home-notice-close" type="button" data-notice-close aria-label="关闭公告">×</button>
      <div class="home-notice-head">
        <span class="home-notice-icon" data-notice-icon aria-hidden="true">💗</span>
        <div>
          <p data-notice-date>Today</p>
          <h2 id="home-notice-title" data-notice-title>Yuimi Lab 今日公告</h2>
        </div>
      </div>
      <div class="home-notice-body" data-notice-body></div>
      <label class="home-notice-skip">
        <input type="checkbox" data-notice-skip />
        <span>今日不再弹出</span>
      </label>
    </section>
  </div>

  <div class="scene-divider" aria-hidden="true">
    <div class="scene-divider__rail">
      <span class="scene-divider__glow"></span>
      <span class="scene-divider__stitch"></span>
      <span class="scene-divider__note note-a"></span>
      <span class="scene-divider__note note-b"></span>
      <span class="scene-divider__note note-c"></span>
      <span class="scene-divider__spark spark-a"></span>
      <span class="scene-divider__spark spark-b"></span>
      <span class="scene-divider__spark spark-c"></span>
    </div>
  </div>

  <div class="home-content-bg">
    <section class="tag-rain-stage" id="main-content" data-tag-rain data-tags={JSON.stringify(fallingTags)} aria-label="Yuimi tag rain">
      <div class="home-art-word" aria-label="Yuimi Lab">
        <span>Yuimi Lab</span>
        <small>anime notes / tiny toys / dev memo</small>
      </div>
      <div class="home-signal-card" aria-label="Local signal">
        <p data-home-date>---- 年 -- 月 -- 日</p>
        <strong data-home-time>--:--:--</strong>
        <span>本地时区 · 气温待接入</span>
      </div>
      <div class="home-welcome-bubble">
        <span aria-hidden="true">“</span>
        <strong>哇，你终于回来了～</strong>
        <p>这里会掉下一点兴趣标签，等它们堆在底下再慢慢消失。</p>
        <span aria-hidden="true">”</span>
      </div>
      <canvas class="tag-rain-canvas" data-tag-rain-canvas aria-hidden="true"></canvas>
    </section>
  </div>

  <script>
    (() => {
      const trigger = document.querySelector("[data-notice-open]");
      const backdrop = document.querySelector("[data-notice-backdrop]");
      const modal = document.querySelector("[data-notice-modal]");
      const closeButton = document.querySelector("[data-notice-close]");
      const skipInput = document.querySelector("[data-notice-skip]");
      const titleTarget = document.querySelector("[data-notice-title]");
      const dateTarget = document.querySelector("[data-notice-date]");
      const iconTarget = document.querySelector("[data-notice-icon]");
      const bodyTarget = document.querySelector("[data-notice-body]");
      if (!trigger || !backdrop || !modal || !closeButton || !skipInput || !titleTarget || !dateTarget || !iconTarget || !bodyTarget) return;

      const festivalEntries = [
        {
          date: "01-01",
          icon: "🎍",
          title: "新年启动",
          tone: "soft",
          lines: ["新的文件夹已经建立，旧的 bug 先假装没有追上来。", "今天适合给自己开一个干净的分支。"]
        },
        {
          date: "02-14",
          icon: "🍫",
          title: "情人节备忘",
          tone: "fun",
          lines: ["今日适合投喂巧克力，也适合给喜欢的角色补一张壁纸。", "单身也没关系，代码会陪你一起报错。"]
        },
        {
          date: "04-04",
          icon: "🌧️",
          title: "清明",
          tone: "serious",
          lines: ["清明时节雨纷纷，一束鲜花祭故人。", "今天把声音放轻一点，把想念放稳一点。"]
        },
        {
          date: "04-05",
          icon: "🌧️",
          title: "清明",
          tone: "serious",
          lines: ["清明时节雨纷纷，一束鲜花祭故人。", "今天把声音放轻一点，把想念放稳一点。"]
        },
        {
          date: "05-20",
          icon: "💗",
          title: "520 出租地雷",
          tone: "chaos",
          lines: ["提供一天伴侣服务，包天 520r，主打一个情绪价值反向拉满。"],
          list: [
            "早上叫起床",
            "中午怀疑你出轨",
            "下午对你阴阳怪气",
            "晚上开始冷暴力",
            "十一点过说分手",
            "零点开始拿刀砸门喊：捅死你 × 很多遍，最后补一句喵"
          ],
          footnote: "本公告仅供抽象整活，请勿真的雇佣危险恋爱 NPC。"
        },
        {
          date: "06-01",
          icon: "🧸",
          title: "儿童节玩具箱",
          tone: "fun",
          lines: ["今天允许把自己切回试玩版人格。", "正经事可以做，但必须先摸一下可爱按钮。"]
        },
        {
          date: "10-01",
          icon: "🍁",
          title: "假期模式",
          tone: "soft",
          lines: ["今天适合慢一点打开网页，慢一点听歌。", "把 TODO 放到旁边，先给自己倒一杯快乐。"]
        },
        {
          date: "12-25",
          icon: "🎄",
          title: "圣诞小纸条",
          tone: "fun",
          lines: ["礼物未必从烟囱来，也可能从 npm install 里冒出来。", "祝你今晚的报错都长得像彩灯。"]
        }
      ];

      const solarTerms2026 = [
        ["01-05", "小寒", "风开始认真营业，热饮也该进入常驻快捷栏。"],
        ["01-20", "大寒", "一年最冷的尾声，适合把被窝升级成主机房。"],
        ["02-04", "立春", "春天开始加载，进度条先开一点点。"],
        ["02-18", "雨水", "雨水到，适合给旧计划浇一点新精神。"],
        ["03-05", "惊蛰", "惊蛰一响，沉睡的灵感开始翻身。"],
        ["03-20", "春分", "昼夜平分，摸鱼和努力也暂时平分。"],
        ["04-20", "谷雨", "谷雨落下，适合播种一个长期项目。"],
        ["05-05", "立夏", "夏天入场，冰饮和新坑都开始冒泡。"],
        ["05-21", "小满", "小满未满，留一点余地给下一次更新。"],
        ["06-05", "芒种", "忙种也忙写，灵感像种子一样到处乱飞。"],
        ["06-21", "夏至", "白昼拉满，适合把喜欢的歌循环到天亮。"],
        ["07-07", "小暑", "小暑上线，风扇和冰块加入队伍。"],
        ["07-23", "大暑", "大暑热到出框，建议给 CPU 和自己都降温。"],
        ["08-07", "立秋", "秋天开始排队，夏天还在赖场。"],
        ["08-23", "处暑", "暑气准备退勤，快乐还可以加班。"],
        ["09-07", "白露", "白露微凉，适合整理收藏夹。"],
        ["09-23", "秋分", "秋分到，昼夜重新握手言和。"],
        ["10-08", "寒露", "寒露上桌，外套进入每日构建。"],
        ["10-23", "霜降", "霜降之后，热饮优先级上升。"],
        ["11-07", "立冬", "冬天启动，给心情加一层毛茸茸缓存。"],
        ["11-22", "小雪", "小雪轻轻落，适合开一首安静的歌。"],
        ["12-07", "大雪", "大雪已至，窝在室内也算一种冒险。"],
        ["12-22", "冬至", "冬至快乐，今天适合吃点热乎的。"]
      ].map(([date, title, text]) => ({ date, icon: "🌿", title, tone: "solar", lines: [text] }));

      const historyEntries = [
        {
          date: "05-20",
          icon: "👖",
          title: "今天的趣味历史",
          tone: "history",
          lines: ["1873 年的今天，蓝色牛仔裤相关专利获批。也就是说，今天可以理直气壮地把裤子写进文明史。"]
        },
        {
          date: "03-14",
          icon: "🥧",
          title: "圆周率日",
          tone: "history",
          lines: ["今天适合吃派，也适合假装自己能背到小数点后很多位。"]
        },
        {
          date: "09-09",
          icon: "🐛",
          title: "Bug 小传闻",
          tone: "history",
          lines: ["据说早期计算机真的被虫子打扰过，今天适合温柔地称呼 bug 为历史遗产。"]
        }
      ];

      const formatKey = (date) => `${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
      const formatStorageKey = (date) => `${date.getFullYear()}-${formatKey(date)}`;
      const today = new Date();
      const todayKey = formatKey(today);
      const storageKey = `yuimi-notice-hidden-${formatStorageKey(today)}`;
      let lockedScrollY = 0;

      const todayEntries = [
        ...festivalEntries.filter((item) => item.date === todayKey),
        ...solarTerms2026.filter((item) => item.date === todayKey),
        ...historyEntries.filter((item) => item.date === todayKey)
      ];

      const entries = todayEntries.length > 0
        ? todayEntries
        : [{
          icon: "💌",
          title: "今日小公告",
          tone: "soft",
          lines: ["今天没有撞上特别节日，那就把普通日子当成隐藏关卡。", "请领取一份随机精神补丁：可爱 +1，拖延 -0.5。"]
        }];

      const primary = entries[0];
      iconTarget.textContent = primary.icon;
      titleTarget.textContent = primary.title;
      dateTarget.textContent = new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        weekday: "long"
      }).format(today);
      modal.dataset.tone = primary.tone || "soft";

      bodyTarget.innerHTML = entries.map((entry, index) => `
        <article class="home-notice-entry ${index === 0 ? "is-primary" : ""}">
          <div class="home-notice-entry-title">
            <span aria-hidden="true">${entry.icon}</span>
            <strong>${entry.title}</strong>
          </div>
          ${entry.lines.map((line) => `<p>${line}</p>`).join("")}
          ${entry.list ? `<ol>${entry.list.map((item) => `<li>${item}</li>`).join("")}</ol>` : ""}
          ${entry.footnote ? `<small>${entry.footnote}</small>` : ""}
        </article>
      `).join("");

      const openNotice = () => {
        lockedScrollY = window.scrollY || document.documentElement.scrollTop || 0;
        document.documentElement.classList.add("is-notice-open");
        document.body.classList.add("is-notice-open");
        document.body.style.top = `-${lockedScrollY}px`;
        backdrop.hidden = false;
        backdrop.classList.add("is-open");
        closeButton.focus({ preventScroll: true });
      };

      const closeNotice = () => {
        if (skipInput.checked) {
          try {
            localStorage.setItem(storageKey, "1");
          } catch {
            // Ignore storage failures; the modal can still close normally.
          }
        }
        backdrop.classList.remove("is-open");
        document.documentElement.classList.remove("is-notice-open");
        document.body.classList.remove("is-notice-open");
        document.body.style.top = "";
        window.scrollTo({ top: lockedScrollY, left: 0, behavior: "instant" });
        window.setTimeout(() => {
          backdrop.hidden = true;
        }, 180);
      };

      trigger.addEventListener("click", openNotice);
      closeButton.addEventListener("click", closeNotice);
      backdrop.addEventListener("click", (event) => {
        if (event.target === backdrop) closeNotice();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !backdrop.hidden) closeNotice();
      });

      let hiddenToday = false;
      try {
        hiddenToday = localStorage.getItem(storageKey) === "1";
      } catch {
        hiddenToday = false;
      }

      if (!hiddenToday) {
        window.setTimeout(openNotice, 520);
      }
    })();
  </script>

  <script>
    (() => {
      const stage = document.querySelector("[data-tag-rain]");
      const canvas = document.querySelector("[data-tag-rain-canvas]");
      if (!stage || !canvas) return;

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const labels = (() => {
        try {
          const parsed = JSON.parse(stage.dataset.tags || "[]");
          return [...new Set(Array.isArray(parsed) ? parsed : [])];
        } catch {
          return [];
        }
      })();

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const pigImage = new Image();
      pigImage.src = "/assets/mini-pig-scroll.png";
      const dateTarget = document.querySelector("[data-home-date]");
      const timeTarget = document.querySelector("[data-home-time]");

      const updateHomeClock = () => {
        const now = new Date();
        if (dateTarget) {
          dateTarget.textContent = new Intl.DateTimeFormat("zh-CN", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            weekday: "long"
          }).format(now);
        }
        if (timeTarget) {
          timeTarget.textContent = new Intl.DateTimeFormat("zh-CN", {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: false
          }).format(now);
        }
      };
      updateHomeClock();
      window.setInterval(updateHomeClock, 1000);

      const palette = [
        { fill: "#fff5bf", stroke: "#f0c95a", ink: "#725d22" },
        { fill: "#ffddea", stroke: "#f2a8bd", ink: "#824759" },
        { fill: "#dff2ff", stroke: "#9fc8eb", ink: "#315a78" },
        { fill: "#dff5ea", stroke: "#9bd6b7", ink: "#315e49" },
        { fill: "#eee4ff", stroke: "#c9b8ef", ink: "#57467b" }
      ];

      const state = {
        bodies: [],
        queue: [],
        started: false,
        finishedDropping: false,
        fading: false,
        done: false,
        raf: 0,
        lastTime: 0,
        nextDrop: 0,
        lastDropAt: 0,
        width: 1,
        height: 1,
        stageHeight: 1,
        dpr: 1,
        fadeStart: 0,
        visible: true
      };

      const random = (min, max) => min + Math.random() * (max - min);
      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

      const measureTag = (label) => {
        ctx.save();
        ctx.font = "850 18px 'Cascadia Code', 'Fira Code', Consolas, sans-serif";
        const width = clamp(ctx.measureText(label).width + 46, 96, Math.min(260, state.width * 0.76));
        ctx.restore();
        return { width, height: 44 };
      };

      const makeTag = (label, index) => {
        const size = measureTag(label);
        const color = palette[index % palette.length];
        const radius = Math.max(size.width, size.height) * 0.34;
        return {
          type: "tag",
          label,
          color,
          width: size.width,
          height: size.height,
          radius,
          x: random(radius + 12, state.width - radius - 12),
          y: -random(60, 260),
          vx: random(-1.2, 1.2),
          vy: random(0.5, 1.8),
          angle: random(-0.3, 0.3),
          spin: random(-0.018, 0.018),
          alpha: 1
        };
      };

      const makePig = (index) => {
        const size = random(42, 58);
        const radius = size * 0.52;
        return {
          type: "pig",
          width: size,
          height: size * 0.78,
          radius,
          x: random(radius + 14, state.width - radius - 14),
          y: -random(80, 320),
          vx: random(-1.5, 1.5),
          vy: random(0.4, 1.6),
          angle: random(-0.35, 0.35),
          spin: random(-0.02, 0.02),
          alpha: 1,
          index
        };
      };

      const resize = () => {
        const rect = stage.getBoundingClientRect();
        state.dpr = clamp(window.devicePixelRatio || 1, 1, 2);
        state.width = Math.max(1, Math.floor(rect.width));
        state.stageHeight = Math.max(1, Math.floor(rect.height));
        state.height = state.stageHeight + 80;
        canvas.width = Math.floor(state.width * state.dpr);
        canvas.height = Math.floor(state.height * state.dpr);
        canvas.style.width = state.width + "px";
        canvas.style.height = state.height + "px";
        ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      };

      const prepareQueue = () => {
        const tagBodies = labels.map(makeTag);
        const pigCount = Math.max(3, Math.min(6, Math.round(labels.length / 6)));
        const pigBodies = Array.from({ length: pigCount }, (_, index) => makePig(index));
        state.queue = [...tagBodies, ...pigBodies].sort(() => Math.random() - 0.5);
      };

      const startRain = () => {
        if (state.started || state.done || labels.length === 0) return;
        resize();
        prepareQueue();
        state.started = true;
        state.lastTime = performance.now();
        state.nextDrop = 0;
        stage.classList.add("is-raining");
        state.raf = window.requestAnimationFrame(tick);
      };

      const resetRain = () => {
        if (!state.started && !state.done && state.bodies.length === 0) return;
        window.cancelAnimationFrame(state.raf);
        state.bodies = [];
        state.queue = [];
        state.started = false;
        state.finishedDropping = false;
        state.fading = false;
        state.done = false;
        state.raf = 0;
        state.lastTime = performance.now();
        state.nextDrop = 0;
        state.lastDropAt = 0;
        state.fadeStart = 0;
        stage.classList.remove("is-raining", "is-fading");
        ctx.clearRect(0, 0, state.width, state.height);
      };

      const drawCapsule = (body) => {
        const r = body.height / 2;
        ctx.save();
        ctx.globalAlpha = body.alpha;
        ctx.translate(body.x, body.y);
        ctx.rotate(body.angle);
        ctx.beginPath();
        ctx.roundRect(-body.width / 2, -body.height / 2, body.width, body.height, r);
        ctx.fillStyle = body.color.fill;
        ctx.strokeStyle = body.color.stroke;
        ctx.lineWidth = 2;
        ctx.shadowColor = "rgba(98, 111, 133, 0.16)";
        ctx.shadowBlur = 14;
        ctx.shadowOffsetY = 8;
        ctx.fill();
        ctx.shadowColor = "transparent";
        ctx.stroke();
        ctx.fillStyle = body.color.ink;
        ctx.font = "850 18px 'Cascadia Code', 'Fira Code', Consolas, sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillText(body.label, 0, 1, body.width - 34);
        ctx.restore();
      };

      const drawPig = (body) => {
        ctx.save();
        ctx.globalAlpha = body.alpha;
        ctx.translate(body.x, body.y);
        ctx.rotate(body.angle);
        if (pigImage.complete && pigImage.naturalWidth > 0) {
          ctx.drawImage(pigImage, -body.width / 2, -body.height / 2, body.width, body.height);
        } else {
          ctx.fillStyle = "#ffd5df";
          ctx.strokeStyle = "#ef9db3";
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.roundRect(-body.width / 2, -body.height / 2, body.width, body.height, 18);
          ctx.fill();
          ctx.stroke();
          ctx.fillStyle = "#6f5160";
          ctx.font = "900 14px sans-serif";
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          ctx.fillText("pig", 0, 1);
        }
        ctx.restore();
      };

      const collideBodies = () => {
        for (let i = 0; i < state.bodies.length; i += 1) {
          for (let j = i + 1; j < state.bodies.length; j += 1) {
            const a = state.bodies[i];
            const b = state.bodies[j];
            const dx = b.x - a.x;
            const dy = b.y - a.y;
            const distance = Math.hypot(dx, dy) || 0.001;
            const minDistance = a.radius + b.radius;
            if (distance >= minDistance) continue;

            const nx = dx / distance;
            const ny = dy / distance;
            const overlap = (minDistance - distance) * 0.52;
            a.x -= nx * overlap;
            a.y -= ny * overlap;
            b.x += nx * overlap;
            b.y += ny * overlap;

            const relVx = b.vx - a.vx;
            const relVy = b.vy - a.vy;
            const impulse = (relVx * nx + relVy * ny) * 0.62;
            if (impulse < 0) {
              a.vx += impulse * nx;
              a.vy += impulse * ny;
              b.vx -= impulse * nx;
              b.vy -= impulse * ny;
              a.spin *= 0.58;
              b.spin *= 0.58;
            }
          }
        }
      };

      const stepBody = (body, dt) => {
        const floor = state.stageHeight - 24;
        body.vy += 0.055 * dt;
        body.x += body.vx * dt;
        body.y += body.vy * dt;
        body.angle += body.spin * dt;

        if (body.x - body.radius < 10) {
          body.x = body.radius + 10;
          body.vx = Math.abs(body.vx) * 0.52;
          body.spin *= 0.35;
        }
        if (body.x + body.radius > state.width - 10) {
          body.x = state.width - body.radius - 10;
          body.vx = -Math.abs(body.vx) * 0.52;
          body.spin *= 0.35;
        }
        if (body.y + body.radius > floor) {
          body.y = floor - body.radius;
          body.vy *= -0.16;
          body.vx *= 0.62;
          body.spin *= 0.18;
          if (Math.abs(body.vy) < 0.72) body.vy = 0;
          if (Math.abs(body.vx) < 0.16) body.vx = 0;
          if (Math.abs(body.spin) < 0.018) body.spin = 0;
        }

        if (Math.abs(body.vx) + Math.abs(body.vy) < 0.42) {
          body.spin *= 0.72;
          if (Math.abs(body.spin) < 0.02) body.spin = 0;
        }
      };

      const maybeFade = (now) => {
        if (!state.finishedDropping || state.fading) return;
        const calm = state.bodies.every((body) => Math.abs(body.vx) + Math.abs(body.vy) < 1.15);
        if (calm || now - state.lastDropAt > 4800) {
          state.fading = true;
          state.fadeStart = now;
          stage.classList.add("is-fading");
        }
      };

      const tick = (now) => {
        if (!state.visible) {
          state.raf = window.requestAnimationFrame(tick);
          return;
        }

        const dt = clamp((now - state.lastTime) / 16.67, 0.4, 2.1);
        state.lastTime = now;
        ctx.clearRect(0, 0, state.width, state.height);

        if (!state.finishedDropping && now >= state.nextDrop) {
          const next = state.queue.shift();
          if (next) {
            state.bodies.push(next);
            state.lastDropAt = now;
            state.nextDrop = now + random(120, 220);
          } else {
            state.finishedDropping = true;
            state.lastDropAt = now;
          }
        }

        state.bodies.forEach((body) => stepBody(body, dt));
        for (let i = 0; i < 3; i += 1) collideBodies();

        if (state.fading) {
          const fade = clamp((now - state.fadeStart) / 5200, 0, 1);
          state.bodies.forEach((body) => {
            body.alpha = 1 - fade;
            body.y += fade * 0.05 * dt;
          });
          if (fade >= 1) {
            state.done = true;
            stage.classList.remove("is-raining", "is-fading");
            ctx.clearRect(0, 0, state.width, state.height);
            window.cancelAnimationFrame(state.raf);
            return;
          }
        }

        state.bodies.forEach((body) => {
          if (body.type === "pig") drawPig(body);
          else drawCapsule(body);
        });

        maybeFade(now);
        state.raf = window.requestAnimationFrame(tick);
      };

      const shouldStart = () => {
        const rect = stage.getBoundingClientRect();
        const viewport = window.innerHeight || document.documentElement.clientHeight;
        return rect.top <= viewport * 0.46 && rect.bottom >= viewport * 0.34;
      };

      const isAtPageTop = () => {
        const top = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
        return top <= 4;
      };

      const onScroll = () => {
        if (isAtPageTop()) {
          resetRain();
          return;
        }
        if (shouldStart()) startRain();
      };

      resize();
      if (reduceMotion.matches) {
        stage.classList.add("is-reduced-motion");
      } else {
        const observer = "IntersectionObserver" in window
          ? new IntersectionObserver((entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              startRain();
              observer.disconnect();
            }
          }, { rootMargin: "-34% 0px -42% 0px", threshold: 0.02 })
          : null;
        observer?.observe(stage);
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }
      window.addEventListener("resize", () => {
        resize();
        state.bodies.forEach((body) => {
          body.x = clamp(body.x, body.radius + 10, state.width - body.radius - 10);
          body.y = Math.min(body.y, state.stageHeight - 24 - body.radius);
        });
      });
      document.addEventListener("visibilitychange", () => {
        state.visible = document.visibilityState === "visible";
        state.lastTime = performance.now();
      });
      window.addEventListener("pagehide", () => window.cancelAnimationFrame(state.raf));
    })();
  </script>

  <script>
    const stage = document.querySelector("[data-hero-stage]");
    const hero = stage?.querySelector(".hero");
    const typingTarget = document.querySelector("[data-terminal-typing]");
    const nameTarget = document.querySelector("[data-name-typing]");

    const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
    const pullDistance = 240;
    const dockThreshold = 0.44;
    const resetDelay = 360;
    const releaseDelay = 180;
    const terminalLines = [
      "pin --dev-notes --anime-diary",
      "collect \"blue moments\" && write",
      "npm run scrapbook",
      "echo \"做自己想做，想自己所想\""
    ];
    const nameLines = ["喝益胃", "Yuimi-chaya"];

    let pull = 0;
    let state = "idle";
    let resetTimer = 0;
    let releaseTimer = 0;

    const runTypingLoop = (target, lines, writeDelay = 58, eraseDelay = 32, holdDelay = 1250) => {
      if (!target) return;

      let lineIndex = 0;
      let charIndex = 0;
      let deleting = false;

      const tick = () => {
        const line = lines[lineIndex];
        target.textContent = line.slice(0, charIndex);

        if (!deleting && charIndex < line.length) {
          charIndex += 1;
          window.setTimeout(tick, writeDelay);
          return;
        }

        if (!deleting && charIndex === line.length) {
          deleting = true;
          window.setTimeout(tick, holdDelay);
          return;
        }

        if (deleting && charIndex > 0) {
          charIndex -= 1;
          window.setTimeout(tick, eraseDelay);
          return;
        }

        deleting = false;
        lineIndex = (lineIndex + 1) % lines.length;
        window.setTimeout(tick, 360);
      };

      tick();
    };

    if ("scrollRestoration" in history) {
      history.scrollRestoration = "manual";
    }

    if (!location.hash) {
      requestAnimationFrame(() => window.scrollTo({ top: 0, left: 0 }));
    }

    const setProgress = (progress) => {
      if (!hero) return;

      const value = clamp(progress);
      hero.style.setProperty("--avatar-y", `${(1 - value) * 56}vh`);
      hero.style.setProperty("--avatar-scale", `${0.78 + value * 0.22}`);
      hero.style.setProperty("--profile-opacity", `${clamp((value - 0.08) / 0.48)}`);
      hero.style.setProperty("--copy-opacity", `${1 - clamp((value - 0.12) / 0.42)}`);
      hero.style.setProperty("--cue-opacity", `${1 - clamp(value / 0.48)}`);
    };

    const resetPull = () => {
      if (state === "passed") return;
      pull = 0;
      state = "idle";
      hero?.classList.remove("is-docked", "is-pulling");
      setProgress(0);
    };

    const dockProfile = () => {
      pull = pullDistance;
      state = "docked";
      hero?.classList.remove("is-pulling");
      hero?.classList.add("is-docked");
      setProgress(1);

      window.clearTimeout(releaseTimer);
      releaseTimer = window.setTimeout(() => {
        state = "passed";
      }, releaseDelay);
    };

    const handleHeroWheel = (event) => {
      if (!stage || !hero) return;

      const atHeroTop = window.scrollY <= 2 && stage.getBoundingClientRect().top >= -2;
      if (!atHeroTop) {
        state = "passed";
        return;
      }

      if (event.deltaY < 0) {
        event.preventDefault();
        window.clearTimeout(resetTimer);
        window.clearTimeout(releaseTimer);
        pull = state === "passed" || state === "docked"
          ? 0
          : clamp(pull + event.deltaY, 0, pullDistance);
        state = pull > 0 ? "pulling" : "idle";
        hero.classList.toggle("is-pulling", state === "pulling");
        hero.classList.remove("is-docked");
        setProgress(pull / pullDistance);
        resetTimer = window.setTimeout(resetPull, resetDelay);
        return;
      }

      if (state === "passed") return;
      if (state === "docked") {
        event.preventDefault();
        return;
      }

      event.preventDefault();
      window.clearTimeout(resetTimer);

      const resistance = 1 - clamp(pull / pullDistance) * 0.5;
      pull = clamp(pull + event.deltaY * resistance, 0, pullDistance);
      const progress = pull / pullDistance;

      hero.classList.add("is-pulling");
      setProgress(progress);

      if (progress >= dockThreshold) {
        dockProfile();
      } else {
        state = "pulling";
        resetTimer = window.setTimeout(resetPull, resetDelay);
      }
    };

    const handleHeroScroll = () => {
      if (!stage || !hero) return;

      const nativeProgress = clamp(-stage.getBoundingClientRect().top / (window.innerHeight || 1));
      hero.style.setProperty("--hero-dim", `${0.12 + clamp((nativeProgress - 1.05) / 0.25) * 0.12}`);

      if (window.scrollY <= 2 && state === "passed") {
        pull = pullDistance;
        hero.classList.remove("is-pulling");
        hero.classList.add("is-docked");
        setProgress(1);
      }
    };

    runTypingLoop(typingTarget, terminalLines);
    runTypingLoop(nameTarget, nameLines, 96, 46, 1500);

    const pokeAvatar = document.querySelector("[data-poke-avatar]");
    const pokeBubble = document.querySelector("[data-poke-bubble]");
    let lastPokeAt = 0;
    let bubbleTimer = 0;

    const showPokeBubble = (text) => {
      if (!pokeBubble) return;
      pokeBubble.textContent = text;
      pokeBubble.classList.add("is-visible");
      window.clearTimeout(bubbleTimer);
      bubbleTimer = window.setTimeout(() => {
        pokeBubble.classList.remove("is-visible");
      }, 1700);
    };

    pokeAvatar?.addEventListener("pointermove", (event) => {
      const rect = pokeAvatar.getBoundingClientRect();
      const offset = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pokeAvatar.style.setProperty("--flower-sway", `${offset * 9}deg`);
    });

    pokeAvatar?.addEventListener("pointerleave", () => {
      pokeAvatar.style.setProperty("--flower-sway", "0deg");
    });

    pokeAvatar?.addEventListener("dblclick", (event) => {
      event.preventDefault();
      const now = Date.now();
      if (now - lastPokeAt < 10000) {
        showPokeBubble("\u64cd\u4f5c\u592a\u5feb\u5566\uff0c\u4f11\u606f\u4e00\u4e0b\u5427");
        return;
      }

      lastPokeAt = now;
      pokeAvatar.classList.remove("is-poked");
      void pokeAvatar.offsetWidth;
      pokeAvatar.classList.add("is-poked");
      showPokeBubble("\u6233\u5230\u4e86~");
      window.setTimeout(() => pokeAvatar.classList.remove("is-poked"), 720);
    });

    setProgress(0);
    handleHeroScroll();
    window.addEventListener("wheel", handleHeroWheel, { passive: false });
    window.addEventListener("scroll", handleHeroScroll, { passive: true });
    window.addEventListener("resize", handleHeroScroll);
  </script>
</BaseLayout>
