---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { noticeContent } from "@/data/noticeContent";

const noticeContentPayload = JSON.stringify(noticeContent);

const fallingTags = [
  "Unity3D",
  "Blender",
  "UE5",
  "MMD",
  "AstrBot",
  "猫娘",
  "粉毛",
  "病娇",
  "重女",
  "契约之吻",
  "青春猪头少年",
  "无职转生",
  "夏洛特",
  "Summer Pockets",
  "埃罗芒阿老师",
  "游戏人生",
  "超电磁炮",
  "Cyberpunk 2077",
  "THE FINALS",
  "KovaaK's",
  "Aimlabs",
  "Yuimi Radio",
  "Live2D",
  "小游戏"
];
---

<BaseLayout>
  <section class="hero-stage" data-hero-stage>
    <div class="hero">
      <div class="hero-overlay"></div>
      <button class="home-notice-trigger" type="button" data-notice-open aria-haspopup="dialog">
        <span aria-hidden="true">💌</span>
        今日公告
      </button>
      <div class="hero-copy" data-hero-copy>
        <p class="eyebrow">Personal scrapbook / Anime diary</p>
        <h1 data-title="Yuimi Lab">Yuimi Lab</h1>
        <p class="hero-text terminal-line" aria-label="typing subtitle">
          <span class="hero-terminal-badge" aria-hidden="true"></span>
          <span class="hero-terminal-stack">
            <span class="hero-terminal-status" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
            <span class="hero-terminal-command">
              <span class="terminal-prefix">asteria@lab:~$</span>
              <span class="terminal-typing" data-terminal-typing></span>
            </span>
          </span>
          <span class="terminal-cursor" aria-hidden="true"></span>
        </p>
      </div>

      <div class="hero-profile identity-card" data-hero-profile aria-label="Profile">
        <div class="identity-avatar" data-poke-avatar>
          <span class="avatar-flower" aria-hidden="true">
            <span class="avatar-flower__bloom"></span>
          </span>
          <img src="/assets/profile.jpg" alt="Yuimi Lab avatar" width="168" height="168" />
          <span class="avatar-poke-bubble" data-poke-bubble>&#x64CD;&#x4F5C;&#x592A;&#x5FEB;&#x5566;&#xFF0C;&#x4F11;&#x606F;&#x4E00;&#x4E0B;&#x5427;</span>
        </div>
        <div class="identity-terminal" aria-label="identity terminal card">
          <div class="identity-terminal-bar">
            <div class="terminal-dots" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <span class="terminal-title">yuimi-profile.exe</span>
          </div>
          <p class="identity-path">C:\Users\Yuimi\profile</p>
          <p class="identity-command">
            <span class="terminal-prefix">profile@yuimi:~$</span>
            <span data-name-typing></span>
            <span class="terminal-cursor" aria-hidden="true"></span>
          </p>
          <p class="identity-caption">喝益胃 / Yuimi-chaya</p>
          <div class="social-links" aria-label="Social links">
            <a href="https://github.com/Yuimi-chaya" target="_blank" rel="noreferrer" aria-label="GitHub profile">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.29 9.4 7.86 10.93.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.38-3.87-1.38-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 5.98c.98 0 1.96.13 2.88.39 2.19-1.49 3.15-1.18 3.15-1.18.63 1.59.24 2.77.12 3.06.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.7.41.36.77 1.06.77 2.14v3.18c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
              </svg>
              GitHub
            </a>
            <a href="https://space.bilibili.com/494350222" target="_blank" rel="noreferrer" aria-label="Bilibili profile">
              <svg viewBox="0 0 32 32" aria-hidden="true">
                <path d="M11.1 6.4 8.5 3.8a1.4 1.4 0 0 0-2 2l2.7 2.7h-.7A5.5 5.5 0 0 0 3 14v7.2A5.5 5.5 0 0 0 8.5 26h15A5.5 5.5 0 0 0 29 21.2V14a5.5 5.5 0 0 0-5.5-5.5h-.7l2.7-2.7a1.4 1.4 0 0 0-2-2l-2.6 2.6H11.1Zm-2.6 5h15A2.6 2.6 0 0 1 26.1 14v7.2a2.6 2.6 0 0 1-2.6 2.6h-15a2.6 2.6 0 0 1-2.6-2.6V14a2.6 2.6 0 0 1 2.6-2.6Zm2.7 5.1a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2Zm9.6 0a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2Z" />
              </svg>
              Bilibili
            </a>
          </div>
        </div>
      </div>

      <a class="scroll-cue" href="#main-content" aria-label="Scroll to content">
        <span class="scroll-cue__prompt">scroll@home:~$</span>
        <span class="scroll-cue__arrows" aria-hidden="true">
          <span>&gt;</span>
          <span>&gt;</span>
          <span>&gt;</span>
        </span>
      </a>
    </div>
  </section>

  <div class="home-notice-backdrop" data-notice-backdrop hidden>
    <section class="home-notice-modal" role="dialog" aria-modal="true" aria-labelledby="home-notice-title" data-notice-modal>
      <div class="home-notice-scroll-area" data-notice-scroll-area>
        <button class="home-notice-close" type="button" data-notice-close aria-label="关闭公告">×</button>
        <div class="home-notice-head">
          <span class="home-notice-icon" data-notice-icon aria-hidden="true">💗</span>
          <div>
            <p data-notice-date>Today</p>
            <h2 id="home-notice-title" data-notice-title>Yuimi Lab 今日公告</h2>
          </div>
        </div>
        <div class="home-notice-body" data-notice-body></div>
        <label class="home-notice-skip">
          <input type="checkbox" data-notice-skip />
          <span>今日不再弹出</span>
        </label>
      </div>
      <div class="home-notice-scrollbar" data-notice-scrollbar aria-hidden="true">
        <span data-notice-scroll-thumb></span>
      </div>
    </section>
  </div>

  <script type="application/json" id="notice-content-data" set:html={noticeContentPayload}></script>

  <div class="scene-divider" aria-hidden="true">
    <div class="scene-divider__rail">
      <span class="scene-divider__glow"></span>
      <span class="scene-divider__stitch"></span>
      <span class="scene-divider__note note-a"></span>
      <span class="scene-divider__note note-b"></span>
      <span class="scene-divider__note note-c"></span>
      <span class="scene-divider__spark spark-a"></span>
      <span class="scene-divider__spark spark-b"></span>
      <span class="scene-divider__spark spark-c"></span>
    </div>
  </div>

  <div class="home-content-bg">
    <section class="tag-rain-stage" id="main-content" data-tag-rain data-tags={JSON.stringify(fallingTags)} aria-label="Yuimi tag rain">
      <div class="home-art-word" aria-label="Yuimi Lab">
        <span>Yuimi Lab</span>
        <small>anime notes / tiny toys / dev memo</small>
      </div>
      <div class="home-signal-card" aria-label="Local signal">
        <p data-home-date>---- 年 -- 月 -- 日</p>
        <strong data-home-time>--:--:--</strong>
        <span data-home-weather>本地时区 · 气温待接入</span>
      </div>
      <div class="home-welcome-bubble">
        <span aria-hidden="true">“</span>
        <strong>哇，你终于回来了～</strong>
        <p>这里会掉下一点兴趣标签，等它们堆在底下再慢慢消失。</p>
        <span aria-hidden="true">”</span>
      </div>
      <canvas class="tag-rain-canvas" data-tag-rain-canvas aria-hidden="true"></canvas>
    </section>
  </div>

  <script data-astro-rerun>
    (() => {
      window.__yuimiNoticeCleanup?.();
      const noticeCleanupTasks = [];
      window.__yuimiNoticeCleanup = () => {
        noticeCleanupTasks.splice(0).forEach((cleanup) => cleanup());
      };

      const trigger = document.querySelector("[data-notice-open]");
      const backdrop = document.querySelector("[data-notice-backdrop]");
      const modal = document.querySelector("[data-notice-modal]");
      const scrollArea = document.querySelector("[data-notice-scroll-area]");
      const closeButton = document.querySelector("[data-notice-close]");
      const skipInput = document.querySelector("[data-notice-skip]");
      const titleTarget = document.querySelector("[data-notice-title]");
      const dateTarget = document.querySelector("[data-notice-date]");
      const iconTarget = document.querySelector("[data-notice-icon]");
      const bodyTarget = document.querySelector("[data-notice-body]");
      const scrollBar = document.querySelector("[data-notice-scrollbar]");
      const scrollThumb = document.querySelector("[data-notice-scroll-thumb]");
      if (!trigger || !backdrop || !modal || !scrollArea || !closeButton || !skipInput || !titleTarget || !dateTarget || !iconTarget || !bodyTarget) return;

      const noticeData = JSON.parse(document.getElementById("notice-content-data")?.textContent || "{}");
      const formatKey = (date) => `${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
      const formatStorageKey = (date) => `${date.getFullYear()}-${formatKey(date)}`;
      const pickFrom = (items, index) => items[index % items.length];
      const today = new Date();
      const todayKey = formatKey(today);
      const storageKey = `yuimi-notice-hidden-${formatStorageKey(today)}`;
      const sessionStorageKey = `yuimi-notice-opened-session-${formatStorageKey(today)}`;
      let lockedScrollY = 0;

      const dayOfYear = Math.floor((today.getTime() - new Date(today.getFullYear(), 0, 0).getTime()) / 86400000);
      const weekSeed = Math.floor(dayOfYear / 7) + today.getFullYear() * 53;
      const solarTermEntries = (noticeData.solarTerms2026 || []).map(([date, title, text]) => ({
        date,
        icon: "🌿",
        title,
        tone: "solar",
        lines: [text]
      }));
      const historyEntries = (noticeData.histories || []).map(([date, icon, text]) => ({
        date,
        icon,
        title: "今天的趣味历史",
        tone: "history",
        lines: [text]
      }));
      const createFallbackEntry = () => {
        const themes = noticeData.fallbackThemes || [["💌", "今日小公告", "今天没有撞上特别节日，那就把普通日子当成隐藏关卡。"]];
        const actions = noticeData.fallbackActions || ["领取一份随机精神补丁。"];
        const theme = themes[(dayOfYear - 1) % themes.length];
        return {
          icon: theme[0],
          title: `第 ${dayOfYear} 号历史趣味胶囊`,
          tone: "history",
          lines: [theme[2], `今天的随机行动：${actions[(dayOfYear - 1) % actions.length]}`],
          footnote: "没有撞上固定节日时，Yuimi Lab 会按日期投递不同的冷知识胶囊。"
        };
      };
      const createThursdayV50Entry = () => {
        const pool = noticeData.v50;
        if (!pool || today.getDay() !== 4) return null;
        const opener = pickFrom(pool.openers, weekSeed);
        const plot = pickFrom(pool.plots, weekSeed * 3 + dayOfYear);
        const ask = pickFrom(pool.asks, weekSeed * 5 + today.getMonth());
        const ending = pickFrom(pool.endings, weekSeed * 7 + today.getDate());
        return {
          icon: "🍗",
          title: "星期四 V50 电波",
          tone: "fun",
          lines: [`${opener}${plot}。${ask}`, ending],
          footnote: "V50 文案由素材池按周组合生成，版本数很多，但钱包仍有最终解释权。"
        };
      };

      const todayEntries = [
        ...(noticeData.festivals || []).filter((item) => item.date === todayKey),
        ...solarTermEntries.filter((item) => item.date === todayKey),
        ...historyEntries.filter((item) => item.date === todayKey)
      ];
      const thursdayV50 = createThursdayV50Entry();
      if (thursdayV50) todayEntries.push(thursdayV50);

      const entries = todayEntries.length > 0 ? todayEntries : [createFallbackEntry()];

      const primary = entries[0];
      iconTarget.textContent = primary.icon;
      titleTarget.textContent = primary.title;
      dateTarget.textContent = new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        weekday: "long"
      }).format(today);
      modal.dataset.tone = primary.tone || "soft";

      bodyTarget.innerHTML = entries.map((entry, index) => `
        <article class="home-notice-entry ${index === 0 ? "is-primary" : ""}">
          <div class="home-notice-entry-title">
            <span aria-hidden="true">${entry.icon}</span>
            <strong>${entry.title}</strong>
          </div>
          ${entry.lines.map((line) => `<p>${line}</p>`).join("")}
          ${entry.list ? `<ol>${entry.list.map((item) => `<li>${item}</li>`).join("")}</ol>` : ""}
          ${entry.footnote ? `<small>${entry.footnote}</small>` : ""}
        </article>
      `).join("");

      const updateNoticeScrollbar = () => {
        if (!scrollBar || !scrollThumb) return;
        const scrollable = scrollArea.scrollHeight - scrollArea.clientHeight;
        if (scrollable <= 2) {
          scrollBar.classList.add("is-hidden");
          scrollThumb.style.setProperty("--notice-thumb-y", "0px");
          scrollThumb.style.setProperty("--notice-thumb-height", "100%");
          return;
        }

        scrollBar.classList.remove("is-hidden");
        const trackHeight = scrollBar.clientHeight;
        const thumbHeight = Math.max(42, Math.round((scrollArea.clientHeight / scrollArea.scrollHeight) * trackHeight));
        const maxThumbY = Math.max(0, trackHeight - thumbHeight);
        const thumbY = Math.round((scrollArea.scrollTop / scrollable) * maxThumbY);
        scrollThumb.style.setProperty("--notice-thumb-height", `${thumbHeight}px`);
        scrollThumb.style.setProperty("--notice-thumb-y", `${thumbY}px`);
      };

      const openNotice = () => {
        lockedScrollY = window.scrollY || document.documentElement.scrollTop || 0;
        document.documentElement.classList.add("is-notice-open");
        document.body.classList.add("is-notice-open");
        document.body.style.top = `-${lockedScrollY}px`;
        backdrop.hidden = false;
        backdrop.classList.add("is-open");
        closeButton.focus({ preventScroll: true });
        requestAnimationFrame(updateNoticeScrollbar);
      };

      const closeNotice = () => {
        if (skipInput.checked) {
          try {
            localStorage.setItem(storageKey, "1");
          } catch {
            // Ignore storage failures; the modal can still close normally.
          }
        }
        backdrop.classList.remove("is-open");
        document.documentElement.classList.remove("is-notice-open");
        document.body.classList.remove("is-notice-open");
        document.body.style.top = "";
        window.scrollTo({ top: lockedScrollY, left: 0, behavior: "instant" });
        window.setTimeout(() => {
          backdrop.hidden = true;
        }, 180);
      };

      const openNoticeAutomatically = () => {
        try {
          if (sessionStorage.getItem(sessionStorageKey) === "1") return;
          sessionStorage.setItem(sessionStorageKey, "1");
        } catch {
          // Session storage may be blocked, but the page should still work.
        }
        openNotice();
      };

      const stopNoticeWheel = (event) => {
        if (!backdrop.classList.contains("is-open")) return;
        event.stopPropagation();
        if (!scrollArea.contains(event.target)) {
          event.preventDefault();
        }
      };

      trigger.addEventListener("click", openNotice);
      closeButton.addEventListener("click", closeNotice);
      scrollArea.addEventListener("scroll", updateNoticeScrollbar, { passive: true });
      modal.addEventListener("wheel", stopNoticeWheel, { passive: false });
      backdrop.addEventListener("wheel", stopNoticeWheel, { passive: false });
      window.addEventListener("resize", updateNoticeScrollbar);
      const onBackdropClick = (event) => {
        if (event.target === backdrop) closeNotice();
      };
      const onNoticeKeydown = (event) => {
        if (event.key === "Escape" && !backdrop.hidden) closeNotice();
      };
      backdrop.addEventListener("click", onBackdropClick);
      document.addEventListener("keydown", onNoticeKeydown);
      noticeCleanupTasks.push(() => {
        trigger.removeEventListener("click", openNotice);
        closeButton.removeEventListener("click", closeNotice);
        scrollArea.removeEventListener("scroll", updateNoticeScrollbar);
        modal.removeEventListener("wheel", stopNoticeWheel);
        backdrop.removeEventListener("wheel", stopNoticeWheel);
        window.removeEventListener("resize", updateNoticeScrollbar);
        backdrop.removeEventListener("click", onBackdropClick);
        document.removeEventListener("keydown", onNoticeKeydown);
      });

      let hiddenToday = false;
      try {
        hiddenToday = localStorage.getItem(storageKey) === "1";
      } catch {
        hiddenToday = false;
      }

      if (!hiddenToday) {
        const autoOpenTimer = window.setTimeout(openNoticeAutomatically, 520);
        noticeCleanupTasks.push(() => window.clearTimeout(autoOpenTimer));
      }
    })();
  </script>

  <script data-astro-rerun>
    (() => {
      window.__yuimiHomeRainCleanup?.();
      const cleanupTasks = [];
      window.__yuimiHomeRainCleanup = () => {
        cleanupTasks.splice(0).forEach((cleanup) => cleanup());
      };

      const stage = document.querySelector("[data-tag-rain]");
      const canvas = document.querySelector("[data-tag-rain-canvas]");
      if (!stage || !canvas) return;

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const labels = (() => {
        try {
          const parsed = JSON.parse(stage.dataset.tags || "[]");
          return [...new Set(Array.isArray(parsed) ? parsed : [])];
        } catch {
          return [];
        }
      })();

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const pigImage = new Image();
      pigImage.src = "/assets/mini-pig-scroll.png";
      const dateTarget = document.querySelector("[data-home-date]");
      const timeTarget = document.querySelector("[data-home-time]");
      const weatherTarget = document.querySelector("[data-home-weather]");
      const locationCacheKey = "yuimi-home-local-signal-v3";
      const tencentMapKey = "PDHBZ-Q6QAT-W7NXN-VIUTJ-PPEUV-C5F3P";
      const weatherCodeText = {
        0: "晴",
        1: "大致晴朗",
        2: "少云",
        3: "阴",
        45: "雾",
        48: "霜雾",
        51: "毛毛雨",
        53: "毛毛雨",
        55: "毛毛雨",
        61: "小雨",
        63: "中雨",
        65: "大雨",
        71: "小雪",
        73: "中雪",
        75: "大雪",
        80: "阵雨",
        81: "阵雨",
        82: "强阵雨",
        95: "雷雨",
        96: "雷雨夹冰雹",
        99: "雷雨夹冰雹"
      };

      const readJsonCache = (key) => {
        try {
          return JSON.parse(localStorage.getItem(key) ?? "{}");
        } catch {
          return {};
        }
      };

      const writeJsonCache = (key, value) => {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch {
          // ignore storage failures in private browsing
        }
      };

      const jsonp = (url, params = {}, timeout = 7000) => {
        const callbackName = `yuimiMapCallback_${Date.now()}_${Math.random().toString(16).slice(2)}`;
        const query = new URLSearchParams({ ...params, callback: callbackName });
        const separator = url.includes("?") ? "&" : "?";
        const script = document.createElement("script");

        return new Promise((resolve, reject) => {
          const timer = window.setTimeout(() => {
            cleanup();
            reject(new Error("JSONP timeout"));
          }, timeout);

          const cleanup = () => {
            window.clearTimeout(timer);
            delete window[callbackName];
            script.remove();
          };

          window[callbackName] = (data) => {
            cleanup();
            resolve(data);
          };
          script.onerror = () => {
            cleanup();
            reject(new Error("JSONP failed"));
          };
          script.src = `${url}${separator}${query.toString()}`;
          document.head.appendChild(script);
        });
      };

      const jsonpText = (url, params = {}, timeout = 7000) => {
        const callbackName = `yuimiIpCallback_${Date.now()}_${Math.random().toString(16).slice(2)}`;
        const query = new URLSearchParams({ ...params, callback: callbackName });
        const separator = url.includes("?") ? "&" : "?";
        const script = document.createElement("script");

        return new Promise((resolve, reject) => {
          const timer = window.setTimeout(() => {
            cleanup();
            reject(new Error("JSONP timeout"));
          }, timeout);

          const cleanup = () => {
            window.clearTimeout(timer);
            delete window[callbackName];
            script.remove();
          };

          window[callbackName] = (data) => {
            cleanup();
            resolve(data);
          };
          script.onerror = () => {
            cleanup();
            reject(new Error("JSONP failed"));
          };
          script.src = `${url}${separator}${query.toString()}`;
          document.head.appendChild(script);
        });
      };

      const formatSignalLocation = (adInfo) => {
        const parts = [adInfo?.province, adInfo?.city, adInfo?.district]
          .filter(Boolean)
          .filter((item, index, list) => list.indexOf(item) === index);
        if (!parts.length) return adInfo?.nation || "本地时区";
        return parts.join(" ");
      };

      const getTencentIpLocation = async () => {
        const locationData = await jsonp("https://apis.map.qq.com/ws/location/v1/ip", {
          key: tencentMapKey,
          output: "jsonp"
        });
        const result = locationData?.result;
        const location = result?.location;
        if (Number(locationData?.status) !== 0 || !location) throw new Error(locationData?.message || "Tencent location failed");
        return {
          place: formatSignalLocation(result.ad_info),
          latitude: Number(location.lat),
          longitude: Number(location.lng)
        };
      };

      const getFallbackIpLocation = async () => {
        const response = await fetch("https://ipwho.is/?lang=zh-CN");
        if (!response.ok) throw new Error("Fallback location failed");
        const data = await response.json();
        if (!data?.success) throw new Error(data?.message || "Fallback location failed");
        const place = [data.region, data.city].filter(Boolean).join(" ") || data.country || "本地时区";
        return {
          place,
          latitude: Number(data.latitude),
          longitude: Number(data.longitude)
        };
      };

      const getPconlineIpLocation = async () => {
        const response = await fetch("https://whois.pconline.com.cn/ipJson.jsp?json=true");
        if (!response.ok) throw new Error("Pconline location failed");
        const text = await response.text();
        const data = JSON.parse(text.replace(/^\s*callback\(|\)\s*$/g, "").trim());
        const place = [data.pro, data.city, data.region].filter(Boolean).join(" ") || data.addr || "本地时区";
        return {
          place,
          latitude: 31.2304,
          longitude: 121.4737,
          approximate: true
        };
      };

      const getTencentNewsIpLocation = async () => {
        const data = await jsonpText("https://r.inews.qq.com/api/ip2city", {
          otype: "jsonp"
        });
        if (Number(data?.ret) !== 0) throw new Error(data?.errMsg || "Tencent news location failed");
        const place = [data.province, data.city, data.district].filter(Boolean).join(" ") || data.country || "本地时区";
        return {
          place,
          latitude: 31.2304,
          longitude: 121.4737,
          approximate: true
        };
      };

      const getIpLocation = async () => {
        try {
          return await getTencentIpLocation();
        } catch {
          try {
            return await getFallbackIpLocation();
          } catch {
            try {
              return await getTencentNewsIpLocation();
            } catch {
              return getPconlineIpLocation();
            }
          }
        }
      };

      const getTimezoneLocation = () => {
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || "Asia/Shanghai";
        const presets = {
          "Asia/Shanghai": { place: "本地时区", latitude: 31.2304, longitude: 121.4737 },
          "Asia/Tokyo": { place: "东京电波", latitude: 35.6762, longitude: 139.6503 },
          "Asia/Hong_Kong": { place: "香港电波", latitude: 22.3193, longitude: 114.1694 },
          "Asia/Taipei": { place: "台北电波", latitude: 25.033, longitude: 121.5654 }
        };
        return presets[timezone] ?? { place: timezone, latitude: 31.2304, longitude: 121.4737 };
      };

      const updateHomeWeather = async () => {
        if (!weatherTarget) return;
        const cached = readJsonCache(locationCacheKey);
        if (cached.label && Date.now() - Number(cached.updatedAt ?? 0) < 1000 * 60 * 60 * 3) {
          weatherTarget.textContent = cached.label;
          return;
        }
        ["yuimi-home-local-signal-v1", "yuimi-home-local-signal-v2"].forEach((oldKey) => {
          if (localStorage.getItem(oldKey)) localStorage.removeItem(oldKey);
        });
        if (cached.place === "本地时区" || cached.label?.includes("本地时区")) {
          localStorage.removeItem(locationCacheKey);
        }

        weatherTarget.textContent = "定位电波接收中...";
        let location;
        try {
          location = await getIpLocation();
        } catch {
          location = getTimezoneLocation();
        }

        try {
          if (!Number.isFinite(location.latitude) || !Number.isFinite(location.longitude)) {
            throw new Error("No location");
          }

          const weatherUrl = new URL("https://api.open-meteo.com/v1/forecast");
          weatherUrl.searchParams.set("latitude", String(location.latitude));
          weatherUrl.searchParams.set("longitude", String(location.longitude));
          weatherUrl.searchParams.set("current", "temperature_2m,weather_code");
          weatherUrl.searchParams.set("timezone", "auto");
          weatherUrl.searchParams.set("forecast_days", "1");
          const weatherResponse = await fetch(weatherUrl);
          if (!weatherResponse.ok) throw new Error("Weather failed");
          const weatherData = await weatherResponse.json();
          const current = weatherData.current ?? {};
          const temperature = Number(current.temperature_2m);
          const weatherText = weatherCodeText[current.weather_code] ?? "天气";
          const label = Number.isFinite(temperature)
            ? `${location.place} · ${Math.round(temperature)}°C ${weatherText}`
            : `${location.place} · 天气信号微弱`;
          weatherTarget.textContent = label;
          writeJsonCache(locationCacheKey, {
            label,
            place: location.place,
            latitude: location.latitude,
            longitude: location.longitude,
            updatedAt: Date.now()
          });
        } catch {
          const label = `${location.place} · 天气信号迷路中`;
          weatherTarget.textContent = label;
          writeJsonCache(locationCacheKey, {
            label,
            place: location.place,
            latitude: location.latitude,
            longitude: location.longitude,
            updatedAt: Date.now()
          });
        }
      };

      const updateHomeClock = () => {
        const now = new Date();
        if (dateTarget) {
          dateTarget.textContent = new Intl.DateTimeFormat("zh-CN", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            weekday: "long"
          }).format(now);
        }
        if (timeTarget) {
          timeTarget.textContent = new Intl.DateTimeFormat("zh-CN", {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: false
          }).format(now);
        }
      };
      updateHomeClock();
      const clockTimer = window.setInterval(updateHomeClock, 1000);
      cleanupTasks.push(() => window.clearInterval(clockTimer));
      updateHomeWeather();

      const palette = [
        { fill: "#fff5bf", stroke: "#f0c95a", ink: "#725d22" },
        { fill: "#ffddea", stroke: "#f2a8bd", ink: "#824759" },
        { fill: "#dff2ff", stroke: "#9fc8eb", ink: "#315a78" },
        { fill: "#dff5ea", stroke: "#9bd6b7", ink: "#315e49" },
        { fill: "#eee4ff", stroke: "#c9b8ef", ink: "#57467b" }
      ];

      const state = {
        bodies: [],
        queue: [],
        started: false,
        finishedDropping: false,
        fading: false,
        done: false,
        raf: 0,
        lastTime: 0,
        nextDrop: 0,
        lastDropAt: 0,
        width: 1,
        height: 1,
        stageHeight: 1,
        dpr: 1,
        fadeStart: 0,
        visible: true
      };

      const random = (min, max) => min + Math.random() * (max - min);
      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

      const measureTag = (label) => {
        ctx.save();
        ctx.font = "850 18px 'Cascadia Code', 'Fira Code', Consolas, sans-serif";
        const width = clamp(ctx.measureText(label).width + 46, 96, Math.min(260, state.width * 0.76));
        ctx.restore();
        return { width, height: 44 };
      };

      const makeTag = (label, index) => {
        const size = measureTag(label);
        const color = palette[index % palette.length];
        const radius = Math.max(size.width, size.height) * 0.34;
        return {
          type: "tag",
          label,
          color,
          width: size.width,
          height: size.height,
          radius,
          x: random(radius + 12, state.width - radius - 12),
          y: -random(60, 260),
          vx: random(-1.2, 1.2),
          vy: random(0.5, 1.8),
          angle: random(-0.3, 0.3),
          spin: random(-0.018, 0.018),
          alpha: 1
        };
      };

      const makePig = (index) => {
        const size = random(42, 58);
        const radius = size * 0.52;
        return {
          type: "pig",
          width: size,
          height: size * 0.78,
          radius,
          x: random(radius + 14, state.width - radius - 14),
          y: -random(80, 320),
          vx: random(-1.5, 1.5),
          vy: random(0.4, 1.6),
          angle: random(-0.35, 0.35),
          spin: random(-0.02, 0.02),
          alpha: 1,
          index
        };
      };

      const resize = () => {
        const rect = stage.getBoundingClientRect();
        state.dpr = clamp(window.devicePixelRatio || 1, 1, 2);
        state.width = Math.max(1, Math.floor(rect.width));
        state.stageHeight = Math.max(1, Math.floor(rect.height));
        state.height = state.stageHeight + 80;
        canvas.width = Math.floor(state.width * state.dpr);
        canvas.height = Math.floor(state.height * state.dpr);
        canvas.style.width = state.width + "px";
        canvas.style.height = state.height + "px";
        ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      };

      const prepareQueue = () => {
        const tagBodies = labels.map(makeTag);
        const pigCount = Math.max(3, Math.min(6, Math.round(labels.length / 6)));
        const pigBodies = Array.from({ length: pigCount }, (_, index) => makePig(index));
        state.queue = [...tagBodies, ...pigBodies].sort(() => Math.random() - 0.5);
      };

      const startRain = () => {
        if (state.started || state.done || labels.length === 0) return;
        resize();
        prepareQueue();
        state.started = true;
        state.lastTime = performance.now();
        state.nextDrop = 0;
        stage.classList.add("is-raining");
        window.cancelAnimationFrame(state.raf);
        state.raf = window.requestAnimationFrame(tick);
      };

      const resetRain = () => {
        if (!state.started && !state.done && state.bodies.length === 0) return;
        window.cancelAnimationFrame(state.raf);
        state.bodies = [];
        state.queue = [];
        state.started = false;
        state.finishedDropping = false;
        state.fading = false;
        state.done = false;
        state.raf = 0;
        state.lastTime = performance.now();
        state.nextDrop = 0;
        state.lastDropAt = 0;
        state.fadeStart = 0;
        stage.classList.remove("is-raining", "is-fading");
        ctx.clearRect(0, 0, state.width, state.height);
      };

      const drawCapsule = (body) => {
        const r = body.height / 2;
        ctx.save();
        ctx.globalAlpha = body.alpha;
        ctx.translate(body.x, body.y);
        ctx.rotate(body.angle);
        ctx.beginPath();
        ctx.roundRect(-body.width / 2, -body.height / 2, body.width, body.height, r);
        ctx.fillStyle = body.color.fill;
        ctx.strokeStyle = body.color.stroke;
        ctx.lineWidth = 2;
        ctx.shadowColor = "rgba(98, 111, 133, 0.16)";
        ctx.shadowBlur = 14;
        ctx.shadowOffsetY = 8;
        ctx.fill();
        ctx.shadowColor = "transparent";
        ctx.stroke();
        ctx.fillStyle = body.color.ink;
        ctx.font = "850 18px 'Cascadia Code', 'Fira Code', Consolas, sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillText(body.label, 0, 1, body.width - 34);
        ctx.restore();
      };

      const drawPig = (body) => {
        ctx.save();
        ctx.globalAlpha = body.alpha;
        ctx.translate(body.x, body.y);
        ctx.rotate(body.angle);
        if (pigImage.complete && pigImage.naturalWidth > 0) {
          ctx.drawImage(pigImage, -body.width / 2, -body.height / 2, body.width, body.height);
        } else {
          ctx.fillStyle = "#ffd5df";
          ctx.strokeStyle = "#ef9db3";
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.roundRect(-body.width / 2, -body.height / 2, body.width, body.height, 18);
          ctx.fill();
          ctx.stroke();
          ctx.fillStyle = "#6f5160";
          ctx.font = "900 14px sans-serif";
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          ctx.fillText("pig", 0, 1);
        }
        ctx.restore();
      };

      const collideBodies = () => {
        for (let i = 0; i < state.bodies.length; i += 1) {
          for (let j = i + 1; j < state.bodies.length; j += 1) {
            const a = state.bodies[i];
            const b = state.bodies[j];
            const dx = b.x - a.x;
            const dy = b.y - a.y;
            const distance = Math.hypot(dx, dy) || 0.001;
            const minDistance = a.radius + b.radius;
            if (distance >= minDistance) continue;

            const nx = dx / distance;
            const ny = dy / distance;
            const overlap = (minDistance - distance) * 0.52;
            a.x -= nx * overlap;
            a.y -= ny * overlap;
            b.x += nx * overlap;
            b.y += ny * overlap;

            const relVx = b.vx - a.vx;
            const relVy = b.vy - a.vy;
            const impulse = (relVx * nx + relVy * ny) * 0.62;
            if (impulse < 0) {
              a.vx += impulse * nx;
              a.vy += impulse * ny;
              b.vx -= impulse * nx;
              b.vy -= impulse * ny;
              a.spin *= 0.58;
              b.spin *= 0.58;
            }
          }
        }
      };

      const stepBody = (body, dt) => {
        const floor = state.stageHeight - 24;
        body.vy += 0.055 * dt;
        body.x += body.vx * dt;
        body.y += body.vy * dt;
        body.angle += body.spin * dt;

        if (body.x - body.radius < 10) {
          body.x = body.radius + 10;
          body.vx = Math.abs(body.vx) * 0.52;
          body.spin *= 0.35;
        }
        if (body.x + body.radius > state.width - 10) {
          body.x = state.width - body.radius - 10;
          body.vx = -Math.abs(body.vx) * 0.52;
          body.spin *= 0.35;
        }
        if (body.y + body.radius > floor) {
          body.y = floor - body.radius;
          body.vy *= -0.16;
          body.vx *= 0.62;
          body.spin *= 0.18;
          if (Math.abs(body.vy) < 0.72) body.vy = 0;
          if (Math.abs(body.vx) < 0.16) body.vx = 0;
          if (Math.abs(body.spin) < 0.018) body.spin = 0;
        }

        if (Math.abs(body.vx) + Math.abs(body.vy) < 0.42) {
          body.spin *= 0.72;
          if (Math.abs(body.spin) < 0.02) body.spin = 0;
        }
      };

      const maybeFade = (now) => {
        if (!state.finishedDropping || state.fading) return;
        const calm = state.bodies.every((body) => Math.abs(body.vx) + Math.abs(body.vy) < 1.15);
        if (calm || now - state.lastDropAt > 4800) {
          state.fading = true;
          state.fadeStart = now;
          stage.classList.add("is-fading");
        }
      };

      const tick = (now) => {
        if (!state.visible) {
          state.raf = window.requestAnimationFrame(tick);
          return;
        }

        const dt = clamp((now - state.lastTime) / 16.67, 0.4, 2.1);
        state.lastTime = now;
        ctx.clearRect(0, 0, state.width, state.height);

        if (!state.finishedDropping && now >= state.nextDrop) {
          const next = state.queue.shift();
          if (next) {
            state.bodies.push(next);
            state.lastDropAt = now;
            state.nextDrop = now + random(120, 220);
          } else {
            state.finishedDropping = true;
            state.lastDropAt = now;
          }
        }

        state.bodies.forEach((body) => stepBody(body, dt));
        for (let i = 0; i < 3; i += 1) collideBodies();

        if (state.fading) {
          const fade = clamp((now - state.fadeStart) / 5200, 0, 1);
          state.bodies.forEach((body) => {
            body.alpha = 1 - fade;
            body.y += fade * 0.05 * dt;
          });
          if (fade >= 1) {
            state.done = true;
            stage.classList.remove("is-raining", "is-fading");
            ctx.clearRect(0, 0, state.width, state.height);
            window.cancelAnimationFrame(state.raf);
            return;
          }
        }

        state.bodies.forEach((body) => {
          if (body.type === "pig") drawPig(body);
          else drawCapsule(body);
        });

        maybeFade(now);
        state.raf = window.requestAnimationFrame(tick);
      };

      const shouldStart = () => {
        const rect = stage.getBoundingClientRect();
        const viewport = window.innerHeight || document.documentElement.clientHeight;
        return rect.top <= viewport * 0.46 && rect.bottom >= viewport * 0.34;
      };

      const isAtPageTop = () => {
        const top = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
        return top <= 4;
      };

      const onScroll = () => {
        if (isAtPageTop()) {
          resetRain();
          return;
        }
        if (shouldStart()) startRain();
      };

      resize();
      if (reduceMotion.matches) {
        stage.classList.add("is-reduced-motion");
      } else {
        const observer = "IntersectionObserver" in window
          ? new IntersectionObserver((entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              startRain();
              observer.disconnect();
            }
          }, { rootMargin: "-34% 0px -42% 0px", threshold: 0.02 })
          : null;
        observer?.observe(stage);
        window.addEventListener("scroll", onScroll, { passive: true });
        cleanupTasks.push(() => {
          observer?.disconnect();
          window.removeEventListener("scroll", onScroll);
        });
        onScroll();
      }
      const onResize = () => {
        resize();
        state.bodies.forEach((body) => {
          body.x = clamp(body.x, body.radius + 10, state.width - body.radius - 10);
          body.y = Math.min(body.y, state.stageHeight - 24 - body.radius);
        });
      };
      const onVisibilityChange = () => {
        state.visible = document.visibilityState === "visible";
        state.lastTime = performance.now();
        if (state.visible && state.started && !state.done && !state.raf) {
          state.raf = window.requestAnimationFrame(tick);
        }
      };
      const onPageHide = () => {
        window.cancelAnimationFrame(state.raf);
        state.raf = 0;
      };
      window.addEventListener("resize", onResize);
      document.addEventListener("visibilitychange", onVisibilityChange);
      window.addEventListener("pagehide", onPageHide);
      cleanupTasks.push(() => {
        window.cancelAnimationFrame(state.raf);
        window.removeEventListener("resize", onResize);
        document.removeEventListener("visibilitychange", onVisibilityChange);
        window.removeEventListener("pagehide", onPageHide);
      });
    })();
  </script>

  <script data-astro-rerun>
    window.__yuimiHeroCleanup?.();
    const heroCleanupTasks = [];
    window.__yuimiHeroCleanup = () => {
      heroCleanupTasks.splice(0).forEach((cleanup) => cleanup());
    };

    const stage = document.querySelector("[data-hero-stage]");
    const hero = stage?.querySelector(".hero");
    const typingTarget = document.querySelector("[data-terminal-typing]");
    const nameTarget = document.querySelector("[data-name-typing]");

    const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
    const pullDistance = 240;
    const dockThreshold = 0.44;
    const resetDelay = 360;
    const releaseDelay = 180;
    const terminalLines = [
      "pin --dev-notes --anime-diary",
      "collect \"blue moments\" && write",
      "npm run scrapbook",
      "echo \"做自己想做，想自己所想\""
    ];
    const nameLines = ["喝益胃", "Yuimi-chaya"];

    let pull = 0;
    let state = "idle";
    let resetTimer = 0;
    let releaseTimer = 0;
    const typingTimers = new Set();

    const setTypingTimer = (callback, delay) => {
      const timer = window.setTimeout(() => {
        typingTimers.delete(timer);
        callback();
      }, delay);
      typingTimers.add(timer);
    };

    const runTypingLoop = (target, lines, writeDelay = 58, eraseDelay = 32, holdDelay = 1250) => {
      if (!target) return;

      let lineIndex = 0;
      let charIndex = 0;
      let deleting = false;

      const tick = () => {
        const line = lines[lineIndex];
        target.textContent = line.slice(0, charIndex);

        if (!deleting && charIndex < line.length) {
          charIndex += 1;
          setTypingTimer(tick, writeDelay);
          return;
        }

        if (!deleting && charIndex === line.length) {
          deleting = true;
          setTypingTimer(tick, holdDelay);
          return;
        }

        if (deleting && charIndex > 0) {
          charIndex -= 1;
          setTypingTimer(tick, eraseDelay);
          return;
        }

        deleting = false;
        lineIndex = (lineIndex + 1) % lines.length;
        setTypingTimer(tick, 360);
      };

      tick();
    };

    if ("scrollRestoration" in history) {
      history.scrollRestoration = "manual";
    }

    if (!location.hash) {
      requestAnimationFrame(() => window.scrollTo({ top: 0, left: 0 }));
    }

    const setProgress = (progress) => {
      if (!hero) return;

      const value = clamp(progress);
      hero.style.setProperty("--avatar-y", `${(1 - value) * 56}vh`);
      hero.style.setProperty("--avatar-scale", `${0.78 + value * 0.22}`);
      hero.style.setProperty("--profile-opacity", `${clamp((value - 0.08) / 0.48)}`);
      hero.style.setProperty("--copy-opacity", `${1 - clamp((value - 0.12) / 0.42)}`);
      hero.style.setProperty("--cue-opacity", `${1 - clamp(value / 0.48)}`);
    };

    const resetPull = () => {
      if (state === "passed") return;
      pull = 0;
      state = "idle";
      hero?.classList.remove("is-docked", "is-pulling");
      setProgress(0);
    };

    const dockProfile = () => {
      pull = pullDistance;
      state = "docked";
      hero?.classList.remove("is-pulling");
      hero?.classList.add("is-docked");
      setProgress(1);

      window.clearTimeout(releaseTimer);
      releaseTimer = window.setTimeout(() => {
        state = "passed";
      }, releaseDelay);
    };

    const handleHeroWheel = (event) => {
      if (!stage || !hero) return;
      if (document.documentElement.classList.contains("is-notice-open")) return;

      const atHeroTop = window.scrollY <= 2 && stage.getBoundingClientRect().top >= -2;
      if (!atHeroTop) {
        state = "passed";
        return;
      }

      if (event.deltaY < 0) {
        event.preventDefault();
        window.clearTimeout(resetTimer);
        window.clearTimeout(releaseTimer);
        pull = state === "passed" || state === "docked"
          ? 0
          : clamp(pull + event.deltaY, 0, pullDistance);
        state = pull > 0 ? "pulling" : "idle";
        hero.classList.toggle("is-pulling", state === "pulling");
        hero.classList.remove("is-docked");
        setProgress(pull / pullDistance);
        resetTimer = window.setTimeout(resetPull, resetDelay);
        return;
      }

      if (state === "passed") return;
      if (state === "docked") {
        event.preventDefault();
        return;
      }

      event.preventDefault();
      window.clearTimeout(resetTimer);

      const resistance = 1 - clamp(pull / pullDistance) * 0.5;
      pull = clamp(pull + event.deltaY * resistance, 0, pullDistance);
      const progress = pull / pullDistance;

      hero.classList.add("is-pulling");
      setProgress(progress);

      if (progress >= dockThreshold) {
        dockProfile();
      } else {
        state = "pulling";
        resetTimer = window.setTimeout(resetPull, resetDelay);
      }
    };

    const handleHeroScroll = () => {
      if (!stage || !hero) return;

      const nativeProgress = clamp(-stage.getBoundingClientRect().top / (window.innerHeight || 1));
      hero.style.setProperty("--hero-dim", `${0.12 + clamp((nativeProgress - 1.05) / 0.25) * 0.12}`);

      if (window.scrollY <= 2 && state === "passed") {
        pull = pullDistance;
        hero.classList.remove("is-pulling");
        hero.classList.add("is-docked");
        setProgress(1);
      }
    };

    runTypingLoop(typingTarget, terminalLines);
    runTypingLoop(nameTarget, nameLines, 96, 46, 1500);

    const pokeAvatar = document.querySelector("[data-poke-avatar]");
    const pokeBubble = document.querySelector("[data-poke-bubble]");
    let lastPokeAt = 0;
    let bubbleTimer = 0;

    const showPokeBubble = (text) => {
      if (!pokeBubble) return;
      pokeBubble.textContent = text;
      pokeBubble.classList.add("is-visible");
      window.clearTimeout(bubbleTimer);
      bubbleTimer = window.setTimeout(() => {
        pokeBubble.classList.remove("is-visible");
      }, 1700);
    };

    const handlePokeMove = (event) => {
      const rect = pokeAvatar.getBoundingClientRect();
      const offset = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pokeAvatar.style.setProperty("--flower-sway", `${offset * 9}deg`);
    };

    const handlePokeLeave = () => {
      pokeAvatar.style.setProperty("--flower-sway", "0deg");
    };

    const handlePokeDoubleClick = (event) => {
      event.preventDefault();
      const now = Date.now();
      if (now - lastPokeAt < 10000) {
        showPokeBubble("\u64cd\u4f5c\u592a\u5feb\u5566\uff0c\u4f11\u606f\u4e00\u4e0b\u5427");
        return;
      }

      lastPokeAt = now;
      pokeAvatar.classList.remove("is-poked");
      void pokeAvatar.offsetWidth;
      pokeAvatar.classList.add("is-poked");
      showPokeBubble("\u6233\u5230\u4e86~");
      window.setTimeout(() => pokeAvatar.classList.remove("is-poked"), 720);
    };

    pokeAvatar?.addEventListener("pointermove", handlePokeMove);
    pokeAvatar?.addEventListener("pointerleave", handlePokeLeave);
    pokeAvatar?.addEventListener("dblclick", handlePokeDoubleClick);
    heroCleanupTasks.push(() => {
      pokeAvatar?.removeEventListener("pointermove", handlePokeMove);
      pokeAvatar?.removeEventListener("pointerleave", handlePokeLeave);
      pokeAvatar?.removeEventListener("dblclick", handlePokeDoubleClick);
    });

    setProgress(0);
    handleHeroScroll();
    window.addEventListener("wheel", handleHeroWheel, { passive: false });
    window.addEventListener("scroll", handleHeroScroll, { passive: true });
    window.addEventListener("resize", handleHeroScroll);
    window.addEventListener("pageshow", handleHeroScroll);
    heroCleanupTasks.push(() => {
      window.clearTimeout(resetTimer);
      window.clearTimeout(releaseTimer);
      window.clearTimeout(bubbleTimer);
      typingTimers.forEach((timer) => window.clearTimeout(timer));
      typingTimers.clear();
      window.removeEventListener("wheel", handleHeroWheel);
      window.removeEventListener("scroll", handleHeroScroll);
      window.removeEventListener("resize", handleHeroScroll);
      window.removeEventListener("pageshow", handleHeroScroll);
    });
  </script>
</BaseLayout>
