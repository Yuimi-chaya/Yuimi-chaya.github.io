---
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = [
  {
    name: "Dev Toolkit",
    type: "Utility",
    summary: "收纳脚本、工具、自动化流程和开发效率相关的小作品。"
  },
  {
    name: "Frontend Lab",
    type: "Experiment",
    summary: "展示交互实验、动效、UI 组件和一些轻量 Web App。"
  },
  {
    name: "Anime Shelf",
    type: "Archive",
    summary: "以后可以扩展成番剧记录、游戏档案、角色收藏或年度总结。"
  }
];
---

<BaseLayout title="Projects | Yuimi Lab" description="项目、工具和个人实验陈列。">
  <section class="page-title">
    <p class="section-kicker">Works</p>
    <h1>Projects</h1>
    <p>把能代表工程能力、审美偏好和折腾精神的东西，像收藏卡一样放在这里。</p>
  </section>

  <section class="project-grid">
    {
      projects.map((project) => (
        <article class="project-card">
          <span>{project.type}</span>
          <h2>{project.name}</h2>
          <p>{project.summary}</p>
        </article>
      ))
    }
  </section>
</BaseLayout>
