---
import "../styles/global.css";
import { site } from "@/lib/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff8ec" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/assets/pig-favicon.png" />
    <link rel="apple-touch-icon" href="/assets/pig-apple-touch.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="sakura-rain" aria-hidden="true">
      {Array.from({ length: 34 }).map(() => <span></span>)}
    </div>
    <div class="pig-scrollbar" data-pig-scrollbar aria-hidden="true">
      <div class="pig-scrollbar-track">
        <div class="pig-scrollbar-fill"></div>
      </div>
      <div class="pig-scrollbar-pig">
        <span class="pig-scrollbar-snort">哼~ 哼~</span>
        <img src="/assets/mini-pig-scroll.png" alt="" width="56" height="48" />
      </div>
    </div>
    <aside class="toy-dock" aria-label="Yuimi Lab toy dock">
      <button class="toy-dock-handle" type="button" aria-label="打开侧边工具">
        <span>TOOLS</span>
      </button>
      <div class="toy-dock-panel">
        <section class="toy-widget live2d-control-widget" aria-label="Live2D 看板娘控制">
          <div class="toy-widget-title">
            <span>✦</span>
            <strong>Live2D 控制台</strong>
          </div>
          <p class="live2d-status" data-live2d-status>正在唤醒看板娘...</p>
          <div class="live2d-controls">
            <button type="button" data-live2d-toggle>隐藏看板娘</button>
            <button type="button" data-live2d-message>说句话</button>
            <button type="button" data-live2d-model>换模型</button>
            <button type="button" data-live2d-texture>换衣服</button>
          </div>
        </section>

        <section class="toy-widget music-widget" aria-label="音乐播放器">
          <div class="toy-widget-title">
            <span>♫</span>
            <strong>Yuimi Radio</strong>
          </div>
          <div class="record-player" aria-hidden="true">
            <div class="record-arm"></div>
            <div class="record-disc">
              <div class="record-label">
                <img src="/assets/pig-brand.png" alt="" width="42" height="38" />
              </div>
            </div>
          </div>
          <p class="music-track">lofi sakura loop</p>
          <div class="music-progress">
            <span data-music-current>00:00</span>
            <input data-music-seek type="range" min="0" max="100" value="0" step="0.1" aria-label="播放进度" />
            <span data-music-duration>00:00</span>
          </div>
          <div class="music-controls">
            <button type="button" data-music-prev aria-label="上一首">‹</button>
            <button type="button" data-music-toggle aria-label="播放或暂停音乐">▶</button>
            <button type="button" data-music-next aria-label="下一首">›</button>
            <input data-music-volume type="range" min="0" max="1" value="0.28" step="0.01" aria-label="音量" />
          </div>
          <p class="music-note" data-music-note>正在读取歌单...</p>
        </section>

      </div>
    </aside>
    <nav class="custom-context-menu" data-context-menu aria-label="&#x5FEB;&#x6377;&#x83DC;&#x5355;">
      <button type="button" data-context-action="top">&#x2191; &#x56DE;&#x5230;&#x9876;&#x90E8;</button>
      <button type="button" data-context-action="refresh">&#x21BB; &#x5237;&#x65B0;&#x9875;&#x9762;</button>
      <button type="button" data-context-action="home">&#x2302; &#x8FD4;&#x56DE;&#x9996;&#x9875;</button>
      <button type="button" data-context-action="back">&#x2190; &#x540E;&#x9000;</button>
      <button type="button" data-context-action="forward">&#x2192; &#x524D;&#x8FDB;</button>
      <button type="button" data-context-action="copy">&#x29C9; &#x590D;&#x5236;&#x94FE;&#x63A5;</button>
      <button type="button" data-context-action="title">T &#x590D;&#x5236;&#x6807;&#x9898;</button>
      <button type="button" data-context-action="sakura">&#x273F; &#x6A31;&#x82B1;&#x5F00;&#x5173;</button>
    </nav>
    <div class="site-shell">
      <header class="site-header" aria-label="Primary">
        <a class="brand" href="/" aria-label={`${site.name} home`}>
          <img src="/assets/pig-brand.png" alt="" width="40" height="36" />
          <span>{site.name}</span>
        </a>
        <nav class="nav-links" aria-label="Main navigation">
          {
            site.nav.map((item) => (
              <a href={item.href} aria-label={`${item.label}: ${item.hint}`}>
                <span class="nav-icon" aria-hidden="true"><Icon name={item.icon} /></span>
                <span class="nav-label">{item.label}</span>
                <span class="nav-hint">{item.hint}</span>
              </a>
            ))
          }
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer" data-footer-timers>
        <div class="footer-inner">
          <p class="footer-signature-line">© 2026 BY 喝益胃 / Yuimi Lab</p>
          <p>二次元手账、开发记录、还有一点点宇宙回声。</p>
          <p>🛰️ 旅行者一号：<time data-elapsed-from="1977-09-05T12:56:00Z" data-elapsed-mode="minute">计算中...</time> 仍在远航</p>
          <p>🛰️ 旅行者二号：<time data-elapsed-from="1977-08-20T14:29:00Z" data-elapsed-mode="minute">计算中...</time> 仍在远航</p>
          <p>🌸 Yuimi Lab 已落地：<time data-elapsed-from="2026-05-18T00:00:00+08:00" data-elapsed-mode="second">计算中...</time></p>
          <p>💍 契约之吻：<time data-elapsed-from="2022-09-24T00:00:00+08:00" data-elapsed-mode="days">计算中...</time>，第二季仍未响应</p>
          <p class="footer-status-line">sakura: falling / pig: on duty / tea: warm</p>
        </div>
      </footer>
    </div>
    <script>
      const pigScrollbar = document.querySelector("[data-pig-scrollbar]");
      let pigScrollTimer = 0;

      const updatePigScrollbar = () => {
        if (!pigScrollbar) return;

        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
        const track = pigScrollbar.querySelector(".pig-scrollbar-track");
        const trackHeight = track?.getBoundingClientRect().height ?? 0;
        const pigY = 20 + progress * trackHeight;
        pigScrollbar.style.setProperty("--scroll-progress", `${Math.min(1, Math.max(0, progress))}`);
        pigScrollbar.style.setProperty("--scroll-percent", `${Math.min(1, Math.max(0, progress)) * 100}%`);
        pigScrollbar.style.setProperty("--pig-y", `${pigY}px`);
        pigScrollbar.classList.add("is-moving");
        window.clearTimeout(pigScrollTimer);
        pigScrollTimer = window.setTimeout(() => {
          pigScrollbar.classList.remove("is-moving");
        }, 260);
      };

      updatePigScrollbar();
      window.addEventListener("scroll", updatePigScrollbar, { passive: true });
      window.addEventListener("resize", updatePigScrollbar);

      const timerNodes = document.querySelectorAll("[data-elapsed-from]");
      const padTimer = (value) => String(value).padStart(2, "0");
      const getElapsedParts = (startDate) => {
        const diff = Math.max(0, Date.now() - startDate.getTime());
        const totalSeconds = Math.floor(diff / 1000);
        return {
          days: Math.floor(totalSeconds / 86400),
          hours: Math.floor((totalSeconds % 86400) / 3600),
          minutes: Math.floor((totalSeconds % 3600) / 60),
          seconds: totalSeconds % 60
        };
      };

      const formatElapsed = (startDate, mode = "second") => {
        const { days, hours, minutes, seconds } = getElapsedParts(startDate);
        if (mode === "minute") {
          return `${days.toLocaleString("zh-CN")}天 ${padTimer(hours)}小时 ${padTimer(minutes)}分`;
        }
        if (mode === "days") {
          return `第 ${days.toLocaleString("zh-CN")} 天`;
        }
        return `${days.toLocaleString("zh-CN")}天 ${padTimer(hours)}小时 ${padTimer(minutes)}分 ${padTimer(seconds)}秒`;
      };

      const updateFooterTimers = () => {
        timerNodes.forEach((node) => {
          const start = new Date(node.dataset.elapsedFrom);
          if (Number.isNaN(start.getTime())) return;
          node.textContent = formatElapsed(start, node.dataset.elapsedMode);
          node.setAttribute("dateTime", start.toISOString());
        });
      };

      updateFooterTimers();
      window.setInterval(updateFooterTimers, 1000);

      const toyDock = document.querySelector(".toy-dock");
      const toyDockHandle = document.querySelector(".toy-dock-handle");
      let toyDockCloseTimer = 0;
      toyDockHandle?.addEventListener("click", () => {
        toyDock?.classList.toggle("is-pinned");
      });
      toyDock?.addEventListener("mouseenter", () => {
        window.clearTimeout(toyDockCloseTimer);
      });
      toyDock?.addEventListener("mouseleave", () => {
        if (toyDock.classList.contains("is-pinned")) return;
        toyDockCloseTimer = window.setTimeout(() => {
          toyDock.querySelector(":focus")?.blur();
        }, 180);
      });
      window.addEventListener("pointerdown", (event) => {
        if (!toyDock || toyDock.contains(event.target)) return;
        toyDock.classList.remove("is-pinned");
        toyDock.querySelector(":focus")?.blur();
      });
      window.addEventListener("keydown", (event) => {
        if (event.key !== "Escape" || !toyDock) return;
        toyDock.classList.remove("is-pinned");
        toyDock.querySelector(":focus")?.blur();
      });

      const live2dBase = "https://fastly.jsdelivr.net/npm/live2d-widgets@1.0.0-rc.6/dist/";
      const live2dStatus = document.querySelector("[data-live2d-status]");
      const live2dToggle = document.querySelector("[data-live2d-toggle]");
      const live2dMessage = document.querySelector("[data-live2d-message]");
      const live2dModel = document.querySelector("[data-live2d-model]");
      const live2dTexture = document.querySelector("[data-live2d-texture]");
      let live2dVisible = true;
      let live2dReady = false;
      let live2dInitStarted = false;

      const setLive2dStatus = (text) => {
        if (live2dStatus) live2dStatus.textContent = text;
      };

      const resetLive2dStorage = () => {
        localStorage.removeItem("waifu-display");
        localStorage.setItem("modelId", "0");
        localStorage.setItem("modelTexturesId", "0");
      };

      const loadExternalResource = (url, type) => new Promise((resolve, reject) => {
        const tag = type === "css" ? document.createElement("link") : document.createElement("script");
        if (type === "css") {
          tag.rel = "stylesheet";
          tag.href = url;
        } else {
          tag.type = "module";
          tag.src = url;
        }
        tag.onload = () => resolve(url);
        tag.onerror = () => reject(url);
        document.head.appendChild(tag);
      });

      const setWaifuVisibility = (visible) => {
        const waifu = document.getElementById("waifu");
        live2dVisible = visible;
        live2dToggle.textContent = visible ? "隐藏看板娘" : "显示看板娘";
        setLive2dStatus(visible ? "看板娘正在左下角待机。" : "看板娘已收起。");
        if (visible) {
          localStorage.removeItem("waifu-display");
        }
        if (!waifu) return;

        if (visible) {
          waifu.classList.remove("waifu-hidden");
          window.setTimeout(() => waifu.classList.add("waifu-active"), 0);
        } else {
          waifu.classList.remove("waifu-active");
          localStorage.setItem("waifu-display", Date.now().toString());
          window.setTimeout(() => waifu.classList.add("waifu-hidden"), 320);
        }
      };

      const showWaifuMessage = (message) => {
        const tips = document.getElementById("waifu-tips");
        if (!tips) return;
        tips.innerHTML = message;
        tips.classList.add("waifu-tips-active");
        window.setTimeout(() => tips.classList.remove("waifu-tips-active"), 4200);
      };

      const waitForWaifu = (callback, retries = 30) => {
        const waifu = document.getElementById("waifu");
        if (waifu) {
          callback(waifu);
          return;
        }
        if (retries <= 0) return;
        window.setTimeout(() => waitForWaifu(callback, retries - 1), 300);
      };

      const ensureLocalWaifuFallback = () => {
        if (document.querySelector(".waifu-local-fallback")) return;
        const fallback = document.createElement("div");
        fallback.className = "waifu-local-fallback";
        fallback.setAttribute("aria-label", "Yuimi Lab fallback 看板娘");
        fallback.innerHTML = `
          <div class="waifu-local-bubble">Live2D 加载有点害羞，先由我值班。</div>
          <div class="waifu-local-character">
            <img src="/assets/profile.jpg" alt="" width="128" height="128" />
          </div>
        `;
        document.body.appendChild(fallback);
      };

      const removeLocalWaifuFallback = () => {
        document.querySelector(".waifu-local-fallback")?.remove();
      };

      const activateWaifuFallbackIfBlank = () => {
        const waifu = document.getElementById("waifu");
        const canvas = document.getElementById("live2d");
        if (!waifu || !canvas || waifu.classList.contains("waifu-hidden")) return;
        const canvasRect = canvas.getBoundingClientRect();
        const hasUsableCanvas = canvasRect.width > 80 && canvasRect.height > 80;
        const hasWidgetTools = Boolean(document.getElementById("waifu-tool"));
        if (hasUsableCanvas && hasWidgetTools) {
          removeLocalWaifuFallback();
          setLive2dStatus("看板娘正在左下角待机。");
          return;
        }
        ensureLocalWaifuFallback();
        setLive2dStatus("Live2D 本体加载不稳定，已启用本地看板娘备用显示。");
      };

      const reconcileWaifuFallback = () => {
        const waifu = document.getElementById("waifu");
        const canvas = document.getElementById("live2d");
        if (!waifu || !canvas || waifu.classList.contains("waifu-hidden")) return;
        const canvasRect = canvas.getBoundingClientRect();
        if (canvasRect.width > 80 && canvasRect.height > 80) {
          removeLocalWaifuFallback();
          setLive2dStatus("看板娘正在左下角待机。");
        }
      };

      const initLive2dWidget = async () => {
        if (live2dInitStarted) return;
        live2dInitStarted = true;
        try {
          resetLive2dStorage();
          await Promise.all([
            loadExternalResource(`${live2dBase}waifu.css`, "css"),
            loadExternalResource(`${live2dBase}waifu-tips.js`, "js")
          ]);
          window.initWidget({
            waifuPath: `${live2dBase}waifu-tips.json`,
            cdnPath: "https://fastly.jsdelivr.net/gh/fghrsh/live2d_api/",
            cubism2Path: `${live2dBase}live2d.min.js`,
            cubism5Path: "https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js",
            tools: ["photo", "quit"],
            logLevel: "warn",
            drag: true
          });
          live2dReady = true;
          live2dVisible = true;
          live2dToggle.textContent = "隐藏看板娘";
          setLive2dStatus("看板娘正在左下角待机。");
          waitForWaifu((waifu) => {
            waifu.classList.remove("waifu-hidden");
            waifu.classList.add("waifu-active");
            window.setTimeout(() => showWaifuMessage("欢迎来到 Yuimi Lab，今天也要开心写代码。"), 900);
            window.setTimeout(reconcileWaifuFallback, 4200);
            window.setTimeout(activateWaifuFallbackIfBlank, 12000);
          });
        } catch (error) {
          live2dInitStarted = false;
          ensureLocalWaifuFallback();
          setLive2dStatus("看板娘加载失败，请检查网络。");
        }
      };

      const hardReloadLive2d = () => {
        removeLocalWaifuFallback();
        document.getElementById("waifu")?.remove();
        document.getElementById("waifu-toggle")?.remove();
        resetLive2dStorage();
        live2dReady = false;
        live2dInitStarted = false;
        initLive2dWidget();
      };

      initLive2dWidget();

      live2dToggle?.addEventListener("click", () => {
        if (!live2dReady && !document.getElementById("waifu")) {
          initLive2dWidget();
          return;
        }
        if (live2dVisible && document.getElementById("waifu") && !document.getElementById("live2d")) {
          hardReloadLive2d();
          return;
        }
        setWaifuVisibility(!live2dVisible);
      });
      live2dMessage?.addEventListener("click", () => {
        setWaifuVisibility(true);
        waitForWaifu((waifu) => waifu.classList.add("waifu-active"));
        window.setTimeout(reconcileWaifuFallback, 800);
        showWaifuMessage("我在这里。要不要继续给博客堆一点可爱的功能？");
      });
      live2dModel?.addEventListener("click", () => {
        hardReloadLive2d();
      });
      live2dTexture?.addEventListener("click", () => {
        hardReloadLive2d();
      });

      const musicToggle = document.querySelector("[data-music-toggle]");
      const musicPrev = document.querySelector("[data-music-prev]");
      const musicNext = document.querySelector("[data-music-next]");
      const musicVolume = document.querySelector("[data-music-volume]");
      const musicSeek = document.querySelector("[data-music-seek]");
      const musicTrack = document.querySelector(".music-track");
      const musicCurrent = document.querySelector("[data-music-current]");
      const musicDuration = document.querySelector("[data-music-duration]");
      const musicNote = document.querySelector("[data-music-note]");
      const musicCacheKey = "yuimi-radio-state-v1";
      const audio = new Audio();
      let musicTracks = [];
      let musicIndex = 0;
      let musicSeeking = false;
      let restoreAutoplay = false;

      const formatAudioTime = (seconds) => {
        if (!Number.isFinite(seconds)) return "00:00";
        const minute = Math.floor(seconds / 60);
        const second = Math.floor(seconds % 60);
        return `${String(minute).padStart(2, "0")}:${String(second).padStart(2, "0")}`;
      };

      const getMusicState = () => {
        try {
          return JSON.parse(localStorage.getItem(musicCacheKey) ?? "{}");
        } catch {
          return {};
        }
      };

      const saveMusicState = () => {
        const currentTrack = musicTracks[musicIndex];
        if (!currentTrack) return;
        localStorage.setItem(
          musicCacheKey,
          JSON.stringify({
            trackId: currentTrack.id,
            currentTime: audio.currentTime || 0,
            volume: audio.volume,
            paused: audio.paused,
            updatedAt: Date.now()
          })
        );
      };

      const updateMusicUi = () => {
        const currentTrack = musicTracks[musicIndex];
        if (musicTrack) musicTrack.textContent = currentTrack?.title ?? "Yuimi Radio";
        if (musicCurrent) musicCurrent.textContent = formatAudioTime(audio.currentTime);
        if (musicDuration) musicDuration.textContent = formatAudioTime(audio.duration);
        if (musicSeek && !musicSeeking) {
          const progress = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
          musicSeek.value = String(progress || 0);
        }
        musicToggle.textContent = audio.paused ? "▶" : "Ⅱ";
        document.body.classList.toggle("is-music-playing", !audio.paused);
      };

      const loadMusicTrack = (index, { keepTime = 0, autoplay = false } = {}) => {
        if (!musicTracks.length) return;
        musicIndex = (index + musicTracks.length) % musicTracks.length;
        const track = musicTracks[musicIndex];
        audio.src = track.src;
        audio.volume = Number(musicVolume?.value ?? 0.28);
        audio.load();
        if (musicNote) musicNote.textContent = `${musicIndex + 1} / ${musicTracks.length}`;
        audio.addEventListener(
          "loadedmetadata",
          async () => {
            if (keepTime > 0 && keepTime < audio.duration - 1) audio.currentTime = keepTime;
            updateMusicUi();
            if (autoplay) {
              try {
                await audio.play();
              } catch {
                if (musicNote) musicNote.textContent = "浏览器需要你点一下播放。";
              }
              updateMusicUi();
            }
          },
          { once: true }
        );
        updateMusicUi();
        saveMusicState();
      };

      const initMusicPlayer = async () => {
        try {
          const response = await fetch("/music/manifest.json", { cache: "no-cache" });
          musicTracks = await response.json();
        } catch {
          musicTracks = [];
        }

        if (!musicTracks.length) {
          if (musicTrack) musicTrack.textContent = "暂无歌曲";
          if (musicNote) musicNote.textContent = "请把 MP3 放入 MUSIC 文件夹。";
          return;
        }

        const cached = getMusicState();
        const cachedIndex = musicTracks.findIndex((track) => track.id === cached.trackId);
        musicIndex = cachedIndex >= 0 ? cachedIndex : 0;
        audio.volume = Number.isFinite(cached.volume) ? cached.volume : Number(musicVolume?.value ?? 0.28);
        if (musicVolume) musicVolume.value = String(audio.volume);
        restoreAutoplay = cached.paused === false;
        loadMusicTrack(musicIndex, {
          keepTime: Number(cached.currentTime ?? 0),
          autoplay: false
        });
        if (restoreAutoplay && musicNote) {
          musicNote.textContent = "已恢复进度，点击播放继续。";
        }
      };

      musicToggle?.addEventListener("click", async () => {
        if (!musicTracks.length) return;
        if (audio.paused) {
          try {
            await audio.play();
          } catch {
            if (musicNote) musicNote.textContent = "浏览器拦截了自动播放，请再点一次。";
          }
        } else {
          audio.pause();
        }
        updateMusicUi();
        saveMusicState();
      });

      musicPrev?.addEventListener("click", () => {
        loadMusicTrack(musicIndex - 1, { autoplay: !audio.paused });
      });

      musicNext?.addEventListener("click", () => {
        loadMusicTrack(musicIndex + 1, { autoplay: !audio.paused });
      });

      musicVolume?.addEventListener("input", () => {
        audio.volume = Number(musicVolume.value);
        saveMusicState();
      });

      musicSeek?.addEventListener("input", () => {
        musicSeeking = true;
        if (!audio.duration) return;
        const target = (Number(musicSeek.value) / 100) * audio.duration;
        if (musicCurrent) musicCurrent.textContent = formatAudioTime(target);
      });

      musicSeek?.addEventListener("change", () => {
        if (audio.duration) {
          audio.currentTime = (Number(musicSeek.value) / 100) * audio.duration;
        }
        musicSeeking = false;
        updateMusicUi();
        saveMusicState();
      });

      audio.addEventListener("timeupdate", () => {
        updateMusicUi();
        saveMusicState();
      });
      audio.addEventListener("play", updateMusicUi);
      audio.addEventListener("pause", () => {
        updateMusicUi();
        saveMusicState();
      });
      audio.addEventListener("ended", () => {
        loadMusicTrack(musicIndex + 1, { autoplay: true });
      });
      window.addEventListener("pagehide", saveMusicState);

      initMusicPlayer();

      const contextMenu = document.querySelector("[data-context-menu]");
      const hideContextMenu = () => contextMenu?.classList.remove("is-open");
      window.addEventListener("contextmenu", (event) => {
        if (!contextMenu) return;
        event.preventDefault();
        const menuWidth = 188;
        const menuHeight = 348;
        const x = Math.min(event.clientX, window.innerWidth - menuWidth - 12);
        const y = Math.min(event.clientY, window.innerHeight - menuHeight - 12);
        contextMenu.style.setProperty("--menu-x", `${Math.max(12, x)}px`);
        contextMenu.style.setProperty("--menu-y", `${Math.max(12, y)}px`);
        contextMenu.classList.add("is-open");
      });
      window.addEventListener("click", hideContextMenu);
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") hideContextMenu();
      });
      contextMenu?.addEventListener("click", async (event) => {
        const button = event.target.closest("[data-context-action]");
        if (!button) return;

        const action = button.dataset.contextAction;
        if (action === "top") window.scrollTo({ top: 0, behavior: "smooth" });
        if (action === "refresh") window.location.reload();
        if (action === "home") window.location.href = "/";
        if (action === "back") history.back();
        if (action === "forward") history.forward();
        if (action === "copy") {
          await navigator.clipboard?.writeText(window.location.href);
          button.textContent = "\u2713 \u94fe\u63a5\u5df2\u590d\u5236";
          window.setTimeout(() => {
            button.textContent = "\u29c9 \u590d\u5236\u94fe\u63a5";
          }, 1200);
        }
        if (action === "title") {
          await navigator.clipboard?.writeText(document.title);
          button.textContent = "\u2713 \u6807\u9898\u5df2\u590d\u5236";
          window.setTimeout(() => {
            button.textContent = "T \u590d\u5236\u6807\u9898";
          }, 1200);
        }
        if (action === "sakura") {
          document.body.classList.toggle("hide-sakura");
        }
        hideContextMenu();
      });

      const enhanceCodeBlocks = () => {
        document.querySelectorAll(".prose pre:not(.expressive-code pre)").forEach((pre) => {
          if (pre.querySelector(".code-block-copy")) return;
          const button = document.createElement("button");
          button.type = "button";
          button.className = "code-block-copy";
          button.textContent = "⧉ Copy";
          button.setAttribute("aria-label", "复制代码");
          button.addEventListener("click", async () => {
            const code = pre.querySelector("code");
            if (!code) return;
            try {
              await navigator.clipboard.writeText(code.textContent ?? "");
              button.textContent = "✓ Copied";
              button.classList.add("copied");
              window.setTimeout(() => {
                button.textContent = "⧉ Copy";
                button.classList.remove("copied");
              }, 1200);
            } catch {
              button.textContent = "Failed";
              window.setTimeout(() => {
                button.textContent = "⧉ Copy";
              }, 1200);
            }
          });
          pre.appendChild(button);
        });
      };

      enhanceCodeBlocks();
      window.addEventListener("load", enhanceCodeBlocks);
    </script>
  </body>
</html>
